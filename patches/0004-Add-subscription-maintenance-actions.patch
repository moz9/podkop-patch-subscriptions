+    local original_mixed_enabled="$2"
+    local original_mixed_port="$3"
+    local mixed_changed="$4"
+
+    [ "$mixed_changed" -eq 1 ] || return 0
+
+    if [ -n "$original_mixed_enabled" ]; then
+        uci -q set "podkop.$section.mixed_proxy_enabled=$original_mixed_enabled"
+    else
+        uci -q delete "podkop.$section.mixed_proxy_enabled"
+    fi
+
+    if [ -n "$original_mixed_port" ]; then
+        uci -q set "podkop.$section.mixed_proxy_port=$original_mixed_port"
+    else
+        uci -q delete "podkop.$section.mixed_proxy_port"
+    fi
+
+    uci commit podkop > /dev/null 2>&1 || return 1
+    config_load "$PODKOP_CONFIG"
+    /etc/init.d/podkop reload > /dev/null 2>&1
