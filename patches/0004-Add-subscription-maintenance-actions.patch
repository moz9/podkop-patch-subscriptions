+    local time_total="$5"
+    local size_download="$6"
+    local http_code="$7"
+
+    jq -cn --arg id "$id" --arg tag "$tag" --arg name "$name" \
+        --argjson bytesPerSecond "$bytes_per_second" \
+        --argjson timeTotal "$time_total" \
+        --argjson sizeDownload "$size_download" \
+        --argjson httpCode "$http_code" \
+        '{id:$id, tag:$tag, name:$name, success:true, bytesPerSecond:$bytesPerSecond, timeTotal:$timeTotal, sizeDownload:$sizeDownload, httpCode:$httpCode}'
+}
