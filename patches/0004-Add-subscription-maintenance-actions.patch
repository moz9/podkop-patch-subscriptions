+async function handleRefreshSubscriptions() {
+  if (!canRunServiceAction()) {
+    return;
+  }
+
+  setActionState({
+    action: 'refresh',
+    actionStatus: 'running',
+    actionMessage: _('Updating subscription configs. Podkop may be reloaded.'),
+  });
+
+  try {
+    const result = await PodkopShellMethods.updateSubscriptions();
+
+    if (!result.success || !result.data.success) {
+      throw new Error(result.success ? result.data.output : result.error);
+    }
+
+    await fetchSubscriptionItems();
+    setActionState({
+      action: 'refresh',
+      actionStatus: 'success',
+      actionMessage: _('Subscription configs updated.'),
+    });
+    showToast(_('Subscription configs updated.'), 'success');
+  } catch (error) {
+    logger.error('[SUBSCRIPTIONS]', 'failed to refresh subscriptions');
+    logger.error('[SUBSCRIPTIONS]', error);
+    setActionState({
+      action: 'refresh',
+      actionStatus: 'error',
+      actionMessage: _(
+        'Failed to update subscription configs. Cache was kept.',
+      ),
+    });
+    showToast(_('Failed to update subscription configs.'), 'error');
+  }
+}
+
+async function handlePingSubscriptions() {
+  if (!canRunServiceAction()) {
+    return;
+  }
+
+  const sections = store.get().subscriptionItemsWidget.data;
+  const latencyByRow: Record<string, number> = {};
+
+  setActionState({
+    action: 'ping',
+    actionStatus: 'running',
+    actionMessage: _('Testing subscription latency.'),
+  });
+
+  try {
+    for (const section of sections) {
+      const enabledItems = getEnabledSupportedItems(section);
+
+      if (!enabledItems.length) {
+        continue;
+      }
+
+      setActionState({
+        action: 'ping',
+        actionStatus: 'running',
+        actionMessage: `${_('Testing latency')}: ${section.displayName}`,
+      });
+
+      const result = await PodkopShellMethods.getClashApiGroupLatency(
+        `${section.code}-out`,
+      );
+
+      if (!result.success) {
+        throw new Error(result.error);
+      }
+
+      enabledItems.forEach((item, index) => {
+        const tag = `${section.code}-${index + 1}-out`;
+        const latency = result.data[tag];
+
+        if (typeof latency === 'number' && latency > 0) {
+          latencyByRow[getRowId(section.code, item.id)] = latency;
+        }
+      });
+    }
+
+    store.set({
+      subscriptionItemsWidget: {
+        ...store.get().subscriptionItemsWidget,
+        latencyByRow,
+      },
+    });
+    setActionState({
+      action: 'ping',
+      actionStatus: 'success',
+      actionMessage: _('Latency test completed.'),
+    });
+    showToast(_('Latency test completed.'), 'success');
+  } catch (error) {
+    logger.error('[SUBSCRIPTIONS]', 'failed to ping subscription configs');
+    logger.error('[SUBSCRIPTIONS]', error);
+    setActionState({
+      action: 'ping',
+      actionStatus: 'error',
+      actionMessage: _('Failed to test latency.'),
+    });
+    showToast(_('Failed to test latency.'), 'error');
+  }
+}
+
+async function handleSpeedtestSubscriptions() {
+  if (!canRunServiceAction()) {
+    return;
+  }
+
+  const sections = store.get().subscriptionItemsWidget.data;
+  const speedByRow: Record<string, Podkop.SubscriptionSpeedtestItem> = {};
+
+  setActionState({
+    action: 'speed',
+    actionStatus: 'running',
+    actionMessage: _(
+      'Running speed benchmark. Active proxy may change briefly.',
+    ),
+  });
+
+  try {
+    for (const section of sections) {
+      const enabledItems = getEnabledSupportedItems(section);
+
+      if (!enabledItems.length) {
+        continue;
+      }
+
+      setActionState({
+        action: 'speed',
+        actionStatus: 'running',
+        actionMessage: `${_('Running speed benchmark')}: ${section.displayName}`,
+      });
+
+      const result = await PodkopShellMethods.benchmarkSubscriptionSection(
+        section.code,
+      );
+
+      if (!result.success || !result.data.success) {
+        throw new Error(result.success ? result.data.error : result.error);
+      }
+
+      (result.data.results ?? []).forEach((item) => {
+        speedByRow[getRowId(section.code, item.id)] = item;
+      });
+    }
+
+    store.set({
+      subscriptionItemsWidget: {
+        ...store.get().subscriptionItemsWidget,
+        speedByRow,
+      },
+    });
+    setActionState({
+      action: 'speed',
+      actionStatus: 'success',
+      actionMessage: _('Speed benchmark completed.'),
+    });
+    showToast(_('Speed benchmark completed.'), 'success');
+  } catch (error) {
+    logger.error('[SUBSCRIPTIONS]', 'failed to run subscription speedtest');
+    logger.error('[SUBSCRIPTIONS]', error);
+    setActionState({
+      action: 'speed',
+      actionStatus: 'error',
+      actionMessage: _('Failed to run speed benchmark.'),
+    });
+    showToast(_('Failed to run speed benchmark.'), 'error');
