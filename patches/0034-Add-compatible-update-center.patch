diff --git a/fe-app-podkop/src/podkop/tabs/diagnostic/partials/renderUpdateCenter.ts b/fe-app-podkop/src/podkop/tabs/diagnostic/partials/renderUpdateCenter.ts
new file mode 100644
index 0000000..df2b9a8
--- /dev/null
+++ b/fe-app-podkop/src/podkop/tabs/diagnostic/partials/renderUpdateCenter.ts
@@ -0,0 +1,131 @@
+import { renderButton } from '../../../../partials';
+import {
+  renderBookOpenTextIcon24,
+  renderCopyIcon24,
+  renderRotateCcwIcon24,
+  renderSearchIcon24,
+} from '../../../../icons';
+import { Podkop } from '../../../types';
+
+interface IRenderUpdateCenterProps {
+  loading: boolean;
+  status: Podkop.SubscriptionPatchUpdateStatus;
+  onCheck: () => void;
+  onUpdate: () => void;
+  onShowLog: () => void;
+  onCopyLog: () => void;
+}
+
+function statusText(status: Podkop.SubscriptionPatchUpdateStatus) {
+  const messages: Record<string, string> = {
+    checking_updates: 'Проверяем обновления и совместимость…',
+    updates_available: 'Доступны совместимые обновления.',
+    up_to_date: 'Podkop и патч актуальны.',
+    patch_update_running: 'Обновление выполняется. Не выключайте роутер.',
+    patch_update_success: 'Обновление установлено и проверено.',
+    patch_update_noop: 'Установлены актуальные версии.',
+    unsupported_podkop:
+      'Новая версия Podkop пока не поддерживается патчем. Обновление заблокировано.',
+    installed_podkop_unsupported:
+      'Установленная версия Podkop не поддерживается этим выпуском патча.',
+    manifest_failed: 'Не удалось загрузить манифест совместимости.',
+    release_check_failed: 'Не удалось получить последнюю версию Podkop.',
+    version_check_failed: 'Не удалось определить версии компонентов.',
+    download_failed: 'Не удалось скачать установщик.',
+    install_failed: 'Установка завершилась ошибкой. Откройте лог.',
+    post_update_verification_failed:
+      'Обновление завершилось, но итоговые версии не прошли проверку.',
+    status_failed: 'Не удалось получить состояние обновления.',
+    worker_stopped: 'Фоновая операция обновления неожиданно остановилась.',
+    busy: 'Другая операция обновления уже выполняется.',
+  };
+  return messages[status.message] || 'Нажмите проверку обновлений.';
+}
+
+function versionValue(current?: string, latest?: string) {
+  if (!current && !latest) return '—';
+  if (!latest || current === latest) return current || latest || '—';
+  return `${current || '—'} → ${latest}`;
+}
+
+export function renderUpdateCenter({
+  loading,
+  status,
+  onCheck,
+  onUpdate,
+  onShowLog,
+  onCopyLog,
+}: IRenderUpdateCenterProps) {
+  const running = ['checking', 'running'].includes(status.state);
+  const hasLog = Boolean(status.logTail);
+  const updateText =
+    status.updateMode === 'patch' ? 'Обновить патч' : 'Обновить всё';
+  const stateClass = [
+    'pdk_diagnostic-update__status',
+    status.state === 'blocked' || status.state === 'error'
+      ? 'pdk_diagnostic-update__status--error'
+      : '',
+    status.state === 'success'
+      ? 'pdk_diagnostic-update__status--success'
+      : '',
+  ]
+    .filter(Boolean)
+    .join(' ');
+
+  return E('div', { class: 'pdk_diagnostic-update' }, [
+    E('b', { class: 'pdk_diagnostic-update__title' }, 'Обновления'),
+    E('div', { class: 'pdk_diagnostic-update__versions' }, [
+      E('div', {}, [
+        E('span', {}, 'Podkop'),
+        E(
+          'b',
+          {},
+          versionValue(
+            status.currentPodkopVersion,
+            status.latestPodkopVersion,
+          ),
+        ),
+      ]),
+      E('div', {}, [
+        E('span', {}, 'Патч'),
+        E(
+          'b',
+          {},
+          versionValue(status.currentPatchVersion, status.latestPatchVersion),
+        ),
+      ]),
+    ]),
+    E('div', { class: stateClass }, statusText(status)),
+    E('div', { class: 'pdk_diagnostic-update__actions' }, [
+      renderButton({
+        onClick: onCheck,
+        icon: renderSearchIcon24,
+        text: 'Проверить',
+        loading: loading && status.state === 'checking',
+        disabled: running,
+      }),
+      renderButton({
+        classNames: ['cbi-button-apply'],
+        onClick: onUpdate,
+        icon: renderRotateCcwIcon24,
+        text: updateText,
+        loading: loading && status.state === 'running',
+        disabled: running || !status.canUpdate,
+      }),
+      renderButton({
+        onClick: onShowLog,
+        icon: renderBookOpenTextIcon24,
+        text: 'Открыть лог',
+        hideText: true,
+        disabled: !hasLog,
+      }),
+      renderButton({
+        onClick: onCopyLog,
+        icon: renderCopyIcon24,
+        text: 'Копировать лог',
+        hideText: true,
+        disabled: !hasLog,
+      }),
+    ]),
+  ]);
+}
