From 52797e271014a5a0ed7e69d8812a05b880ba41ba Mon Sep 17 00:00:00 2001
From: Codex <codex@example.local>
Date: Wed, 17 Jun 2026 23:01:23 +0300
Subject: [PATCH] Reset subscription action state after reload

---
 .../src/podkop/tabs/subscriptions/initController.ts         | 6 ++++++
 .../htdocs/luci-static/resources/view/podkop/main.js        | 6 ++++++
 2 files changed, 12 insertions(+)

diff --git a/fe-app-podkop/src/podkop/tabs/subscriptions/initController.ts b/fe-app-podkop/src/podkop/tabs/subscriptions/initController.ts
index cdb3333..e033efe 100644
--- a/fe-app-podkop/src/podkop/tabs/subscriptions/initController.ts
+++ b/fe-app-podkop/src/podkop/tabs/subscriptions/initController.ts
@@ -110,6 +110,9 @@ async function fetchSubscriptionItems(
         failed: false,
         applying: false,
         status,
+        action: 'none',
+        actionStatus: 'idle',
+        actionMessage: '',
         pendingChanges: {},
         data,
       },
@@ -160,6 +163,9 @@ function handleReset() {
     subscriptionItemsWidget: {
       ...widget,
       status: 'idle',
+      action: 'none',
+      actionStatus: 'idle',
+      actionMessage: '',
       pendingChanges: {},
     },
   });
diff --git a/luci-app-podkop/htdocs/luci-static/resources/view/podkop/main.js b/luci-app-podkop/htdocs/luci-static/resources/view/podkop/main.js
index 707b841..b2e465f 100644
--- a/luci-app-podkop/htdocs/luci-static/resources/view/podkop/main.js
+++ b/luci-app-podkop/htdocs/luci-static/resources/view/podkop/main.js
@@ -5475,6 +5475,9 @@ async function fetchSubscriptionItems(status = "idle") {
         failed: false,
         applying: false,
         status,
+        action: "none",
+        actionStatus: "idle",
+        actionMessage: "",
         pendingChanges: {},
         data
       }
@@ -5515,6 +5518,9 @@ function handleReset() {
     subscriptionItemsWidget: {
       ...widget,
       status: "idle",
+      action: "none",
+      actionStatus: "idle",
+      actionMessage: "",
       pendingChanges: {}
     }
   });
-- 
