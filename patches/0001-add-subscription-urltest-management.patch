diff --git a/fe-app-podkop/src/podkop/tabs/subscriptions/initController.ts b/fe-app-podkop/src/podkop/tabs/subscriptions/initController.ts
new file mode 100644
index 0000000..955264c
--- /dev/null
+++ b/fe-app-podkop/src/podkop/tabs/subscriptions/initController.ts
@@ -0,0 +1,161 @@
+import { onMount, preserveScrollForPage } from '../../../helpers';
+import { showToast } from '../../../helpers/showToast';
+import { CustomPodkopMethods, PodkopShellMethods } from '../../methods';
+import { logger, store, StoreType } from '../../services';
+import { Podkop } from '../../types';
+import { renderSubscriptionSections } from './partials/renderSubscriptionSections';
+
+async function fetchSubscriptionItems() {
+  const prev = store.get().subscriptionItemsWidget;
+
+  store.set({
+    subscriptionItemsWidget: {
+      ...prev,
+      loading: true,
+      failed: false,
+    },
+  });
+
+  try {
+    const configSections = await CustomPodkopMethods.getConfigSections();
+    const subscriptionSections = configSections.filter(
+      (section) =>
+        section.connection_type === 'proxy' &&
+        section.proxy_config_type === 'subscription_urltest',
+    );
+
+    const data = await Promise.all(
+      subscriptionSections.map(async (section) => {
+        const items = await PodkopShellMethods.getSubscriptionItems(
+          section['.name'],
+        );
+
+        return {
+          code: section['.name'],
+          displayName: section['.name'],
+          items: items.success ? items.data : [],
+        };
+      }),
+    );
+
+    store.set({
+      subscriptionItemsWidget: {
+        loading: false,
+        failed: false,
+        updatingId: '',
+        data,
+      },
+    });
+  } catch (_error) {
+    logger.error('[SUBSCRIPTIONS]', 'failed to fetch subscription items');
+
+    store.set({
+      subscriptionItemsWidget: {
+        ...store.get().subscriptionItemsWidget,
+        loading: false,
+        failed: true,
+        updatingId: '',
+      },
+    });
+  }
+}
+
+async function handleToggle(
+  sectionCode: string,
+  item: Podkop.SubscriptionItem,
+  enabled: boolean,
+) {
+  const rowId = `${sectionCode}:${item.id}`;
+
+  store.set({
+    subscriptionItemsWidget: {
+      ...store.get().subscriptionItemsWidget,
+      updatingId: rowId,
+    },
+  });
+
+  const result = await PodkopShellMethods.setSubscriptionLinkEnabled(
+    sectionCode,
+    item.id,
+    enabled,
+  );
+
+  if (!result.success || !result.data.success) {
+    showToast(_('Failed to save!'), 'error');
+  } else {
+    showToast(_('Saved!'), 'success');
+  }
+
+  await fetchSubscriptionItems();
+}
+
+async function renderSubscriptionItemsWidget() {
+  logger.debug('[SUBSCRIPTIONS]', 'renderSubscriptionItemsWidget');
+  const subscriptionItemsWidget = store.get().subscriptionItemsWidget;
+  const container = document.getElementById('subscriptions-sections-grid');
+
+  const renderedWidget = renderSubscriptionSections({
+    loading: subscriptionItemsWidget.loading,
+    failed: subscriptionItemsWidget.failed,
+    sections: subscriptionItemsWidget.data,
+    updatingId: subscriptionItemsWidget.updatingId,
+    onToggle: handleToggle,
+  });
+
+  return preserveScrollForPage(() => {
+    container!.replaceChildren(renderedWidget);
+  });
+}
+
+async function onStoreUpdate(
+  next: StoreType,
+  prev: StoreType,
+  diff: Partial<StoreType>,
+) {
+  if (diff.subscriptionItemsWidget) {
+    renderSubscriptionItemsWidget();
+  }
+}
+
+async function onPageMount() {
+  onPageUnmount();
+
+  store.subscribe(onStoreUpdate);
+
+  await fetchSubscriptionItems();
+}
+
+function onPageUnmount() {
+  store.unsubscribe(onStoreUpdate);
+  store.reset(['subscriptionItemsWidget']);
+}
+
+function registerLifecycleListeners() {
+  store.subscribe((next, prev, diff) => {
+    if (
+      diff.tabService &&
+      next.tabService.current !== prev.tabService.current
+    ) {
+      logger.debug(
+        '[SUBSCRIPTIONS]',
+        'active tab diff event, active tab:',
+        diff.tabService.current,
+      );
+      const isSubscriptionsVisible = next.tabService.current === 'subscriptions';
+
+      if (isSubscriptionsVisible) {
+        return onPageMount();
+      }
+
+      return onPageUnmount();
+    }
+  });
+}
+
+export async function initController(): Promise<void> {
+  onMount('subscriptions-status').then(() => {
+    logger.debug('[SUBSCRIPTIONS]', 'initController', 'onMount');
+    onPageMount();
+    registerLifecycleListeners();
+  });
+}
diff --git a/fe-app-podkop/src/podkop/tabs/subscriptions/partials/renderSubscriptionSections.ts b/fe-app-podkop/src/podkop/tabs/subscriptions/partials/renderSubscriptionSections.ts
new file mode 100644
index 0000000..81e254e
--- /dev/null
+++ b/fe-app-podkop/src/podkop/tabs/subscriptions/partials/renderSubscriptionSections.ts
@@ -0,0 +1,201 @@
+import { Podkop } from '../../../types';
+
+interface RenderSubscriptionSectionsProps {
+  loading: boolean;
+  failed: boolean;
+  sections: Podkop.SubscriptionItemsSection[];
+  updatingId: string;
+  onToggle: (
+    sectionCode: string,
+    item: Podkop.SubscriptionItem,
+    enabled: boolean,
+  ) => void;
+}
+
+function getReasonLabel(reason: string) {
+  const labels: Record<string, string> = {
+    user_excluded: _('Excluded'),
+    unsupported_protocol: _('Unsupported protocol'),
+    unsupported_transport: _('Unsupported transport'),
+    unsupported_security: _('Unsupported security'),
+    invalid_config: _('Invalid config'),
+  };
+
+  return labels[reason] || _('Unsupported config');
+}
+
+function getItemName(item: Podkop.SubscriptionItem, index: number) {
+  return item.name || `${_('Server')} ${index + 1}`;
+}
+
+function getStatusLabel(item: Podkop.SubscriptionItem) {
+  if (!item.supported) {
+    return getReasonLabel(item.reason);
+  }
+
+  return item.enabled ? _('Included') : _('Excluded');
+}
+
+function getStatusClass(item: Podkop.SubscriptionItem) {
+  if (!item.supported) {
+    return 'pdk_subscriptions-page__status--unsupported';
+  }
+
+  return item.enabled
+    ? 'pdk_subscriptions-page__status--enabled'
+    : 'pdk_subscriptions-page__status--excluded';
+}
+
+function renderEmptyState(text: string) {
+  return E(
+    'div',
+    { class: 'pdk_subscriptions-page__empty centered' },
+    text,
+  );
+}
+
+function renderRow({
+  section,
+  item,
+  index,
+  updatingId,
+  enabledSupportedCount,
+  onToggle,
+}: {
+  section: Podkop.SubscriptionItemsSection;
+  item: Podkop.SubscriptionItem;
+  index: number;
+  updatingId: string;
+  enabledSupportedCount: number;
+  onToggle: (
+    sectionCode: string,
+    item: Podkop.SubscriptionItem,
+    enabled: boolean,
+  ) => void;
+}) {
+  const rowId = `${section.code}:${item.id}`;
+  const isUpdating = updatingId === rowId;
+  const isLastEnabled =
+    item.supported && item.enabled && enabledSupportedCount <= 1;
+  const disabled = !item.supported || isUpdating || isLastEnabled;
+
+  return E(
+    'tr',
+    {
+      class: [
+        !item.supported ? 'pdk_subscriptions-page__row--unsupported' : '',
+        isUpdating ? 'pdk_subscriptions-page__row--updating' : '',
+      ]
+        .filter(Boolean)
+        .join(' '),
+    },
+    [
+      E('td', { class: 'pdk_subscriptions-page__toggle-cell' }, [
+        E('input', {
+          type: 'checkbox',
+          checked: item.enabled ? 'checked' : undefined,
+          disabled: disabled ? 'disabled' : undefined,
+          change: (event: Event) => {
+            const target = event.target as HTMLInputElement;
+            onToggle(section.code, item, target.checked);
+          },
+        }),
+      ]),
+      E('td', {}, getItemName(item, index)),
+      E('td', {}, (item.protocol || _('Unknown')).toUpperCase()),
+      E('td', {}, item.transport || _('Default')),
+      E(
+        'td',
+        { class: `pdk_subscriptions-page__status ${getStatusClass(item)}` },
+        isUpdating ? _('Saving') : getStatusLabel(item),
+      ),
+      E('td', {}, `${_('Subscription')} ${item.sourceIndex}`),
+    ],
+  );
+}
+
+function renderSection({
+  section,
+  updatingId,
+  onToggle,
+}: {
+  section: Podkop.SubscriptionItemsSection;
+  updatingId: string;
+  onToggle: (
+    sectionCode: string,
+    item: Podkop.SubscriptionItem,
+    enabled: boolean,
+  ) => void;
+}) {
+  const enabledSupportedCount = section.items.filter(
+    (item) => item.supported && item.enabled,
+  ).length;
+
+  return E('div', { class: 'pdk_subscriptions-page__section' }, [
+    E(
+      'div',
+      { class: 'pdk_subscriptions-page__section-title' },
+      section.displayName,
+    ),
+    section.items.length === 0
+      ? renderEmptyState(_('No subscription configs found'))
+      : E(
+          'div',
+          { class: 'pdk_subscriptions-page__table-wrap' },
+          E('table', { class: 'pdk_subscriptions-page__table' }, [
+            E('thead', {}, [
+              E('tr', {}, [
+                E('th', {}, _('Use')),
+                E('th', {}, _('Config')),
+                E('th', {}, _('Protocol')),
+                E('th', {}, _('Transport')),
+                E('th', {}, _('Status')),
+                E('th', {}, _('Source')),
+              ]),
+            ]),
+            E(
+              'tbody',
+              {},
+              section.items.map((item, index) =>
+                renderRow({
+                  section,
+                  item,
+                  index,
+                  updatingId,
+                  enabledSupportedCount,
+                  onToggle,
+                }),
+              ),
+            ),
+          ]),
+        ),
+  ]);
+}
+
+export function renderSubscriptionSections({
+  loading,
+  failed,
+  sections,
+  updatingId,
+  onToggle,
+}: RenderSubscriptionSectionsProps) {
+  if (loading) {
+    return renderEmptyState(_('Loading'));
+  }
+
+  if (failed) {
+    return renderEmptyState(_('Failed to load subscription configs'));
+  }
+
+  if (sections.length === 0) {
+    return renderEmptyState(_('No Subscription URLTest sections'));
+  }
+
+  return E(
+    'div',
+    { class: 'pdk_subscriptions-page__sections' },
+    sections.map((section) =>
+      renderSection({ section, updatingId, onToggle }),
+    ),
+  );
+}
