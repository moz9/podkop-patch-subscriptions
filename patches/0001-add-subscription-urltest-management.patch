+}
+
+get_subscription_link_id() {
+    local link="$1"
+
+    printf '%s' "$link" | md5sum | awk '{print $1}'
+}
+
+append_subscription_url_to_file() {
+    local subscription_url="$1"
+
+    if [ -n "$subscription_url" ]; then
+        printf '%s\n' "$subscription_url" >> "$SUBSCRIPTION_URLS_FILE"
+        SUBSCRIPTION_URLS_COUNT=$((SUBSCRIPTION_URLS_COUNT + 1))
+    fi
+}
+
+collect_subscription_urls() {
+    local section="$1"
+    local output_file="$2"
+    local subscription_url deduped_file
+
+    : > "$output_file"
+    SUBSCRIPTION_URLS_FILE="$output_file"
+    SUBSCRIPTION_URLS_COUNT=0
+    config_list_foreach "$section" "subscription_url" append_subscription_url_to_file
+
+    if [ "$SUBSCRIPTION_URLS_COUNT" -eq 0 ]; then
+        config_get subscription_url "$section" "subscription_url"
+        set -f
+        for subscription_url in $subscription_url; do
+            append_subscription_url_to_file "$subscription_url"
+        done
+        set +f
+    fi
+
+    if [ ! -s "$output_file" ]; then
+        return 1
+    fi
+
+    deduped_file="$(mktemp)"
+    awk '!seen[$0]++' "$output_file" > "$deduped_file"
+    mv "$deduped_file" "$output_file"
+}
+
+append_subscription_excluded_id_to_file() {
+    local link_id="$1"
+
+    if [ "${#link_id}" -ne 32 ]; then
+        return 0
+    fi
+
+    case "$link_id" in
+    *[!A-Fa-f0-9]*) return 0 ;;
+    esac
+
+    printf '%s\n' "$link_id" >> "$SUBSCRIPTION_EXCLUDED_IDS_FILE"
+    SUBSCRIPTION_EXCLUDED_IDS_COUNT=$((SUBSCRIPTION_EXCLUDED_IDS_COUNT + 1))
+}
+
+collect_subscription_excluded_ids() {
+    local section="$1"
+    local output_file="$2"
+    local link_id deduped_file
+
+    : > "$output_file"
+    SUBSCRIPTION_EXCLUDED_IDS_FILE="$output_file"
+    SUBSCRIPTION_EXCLUDED_IDS_COUNT=0
+    config_list_foreach "$section" "subscription_excluded_link_ids" append_subscription_excluded_id_to_file
+
+    if [ "$SUBSCRIPTION_EXCLUDED_IDS_COUNT" -eq 0 ]; then
+        config_get link_id "$section" "subscription_excluded_link_ids"
+        set -f
+        for link_id in $link_id; do
+            append_subscription_excluded_id_to_file "$link_id"
+        done
+        set +f
+    fi
+
+    deduped_file="$(mktemp)"
+    awk '!seen[$0]++' "$output_file" > "$deduped_file"
+    mv "$deduped_file" "$output_file"
+}
+
+is_subscription_link_id_excluded() {
+    local link_id="$1"
+    local excluded_ids_file="$2"
+
+    [ -s "$excluded_ids_file" ] && grep -Fxq "$link_id" "$excluded_ids_file"
+}
+
+section_has_subscription_urls() {
+    local section="$1"
+    local urls_file
+
+    urls_file="$(mktemp)"
+    if collect_subscription_urls "$section" "$urls_file"; then
+        rm -f "$urls_file"
+        return 0
+    fi
+
+    rm -f "$urls_file"
+    return 1
+}
+
+extract_subscription_proxy_links() {
+    local source_file="$1"
+    local output_file="$2"
+
+    awk '{ gsub(/[[:space:],"\[\]]+/, "\n"); print }' "$source_file" |
+        sed 's/^[>-]*//' |
+        awk '/^[A-Za-z][A-Za-z0-9+.-]*:\/\// { print }' |
+        awk '!seen[$0]++' > "$output_file"
+}
+
+normalize_subscription_file() {
+    local source_file="$1"
+    local output_file="$2"
+    local decoded_file extracted_file
+
+    extracted_file="$(mktemp)"
+    decoded_file="$(mktemp)"
+
+    convert_crlf_to_lf "$source_file"
+    extract_subscription_proxy_links "$source_file" "$extracted_file"
+    if [ -s "$extracted_file" ]; then
+        mv "$extracted_file" "$output_file"
+        rm -f "$decoded_file"
+        return 0
+    fi
+
+    if base64 -d < "$source_file" > "$decoded_file" 2> /dev/null && [ -s "$decoded_file" ]; then
+        convert_crlf_to_lf "$decoded_file"
+        extract_subscription_proxy_links "$decoded_file" "$extracted_file"
+        if [ -s "$extracted_file" ]; then
+            mv "$extracted_file" "$output_file"
+            rm -f "$decoded_file"
+            return 0
+        fi
+    fi
+
+    rm -f "$decoded_file" "$extracted_file"
+    return 1
+}
+
+get_subscription_link_name() {
+    local link="$1"
+    local name
+
+    case "$link" in
+    *#*) name="${link#*#}" ;;
+    *) name="" ;;
+    esac
+
+    [ -n "$name" ] && url_decode "$name"
+}
+
+get_subscription_proxy_skip_reason() {
+    local link="$1"
+    local scheme security transport userinfo decoded_userinfo
+
+    scheme="$(url_get_scheme "$link")"
+    case "$scheme" in
+    vless | ss | trojan | socks4 | socks4a | socks5 | hysteria2 | hy2) ;;
+    *)
+        echo "unsupported_protocol"
+        return 0
+        ;;
+    esac
+
+    case "$scheme" in
+    vless | trojan)
+        transport="$(url_get_query_param "$link" "type")"
+        case "$transport" in
+        "" | tcp | raw | ws | grpc) ;;
+        *)
+            echo "unsupported_transport"
+            return 0
+            ;;
+        esac
+
+        security="$(url_get_query_param "$link" "security")"
+        case "$security" in
+        "" | none | tls | reality) ;;
+        *)
+            echo "unsupported_security"
+            return 0
+            ;;
+        esac
+        ;;
+    ss)
+        userinfo="$(url_get_userinfo "$link")"
+        if ! is_shadowsocks_userinfo_format "$userinfo"; then
+            decoded_userinfo="$(echo "$userinfo" | base64 -d 2> /dev/null)"
+            if [ -z "$decoded_userinfo" ] || ! is_shadowsocks_userinfo_format "$decoded_userinfo"; then
+                echo "invalid_config"
+                return 0
+            fi
+        fi
+        ;;
+    esac
+
+    return 1
+}
+
+append_subscription_skipped_proxy_link() {
+    local link="$1"
+    local reason="$2"
+    local link_id scheme transport name
+
+    link_id="$(get_subscription_link_id "$link")"
+    scheme="$(url_get_scheme "$link")"
+    transport="$(url_get_query_param "$link" "type")"
+    name="$(get_subscription_link_name "$link")"
+
+    jq -cn \
+        --arg id "$link_id" \
+        --arg name "$name" \
+        --arg protocol "$scheme" \
+        --arg transport "$transport" \
+        --arg reason "$reason" \
+        '{id: $id, name: $name, protocol: $protocol, transport: $transport, reason: $reason}' >> "$SUBSCRIPTION_SKIPPED_LINKS_FILE"
+}
+
+append_subscription_item() {
+    local link="$1"
+    local source_index="$2"
+    local supported="$3"
+    local enabled="$4"
+    local reason="$5"
+    local link_id scheme transport name source_name
+
+    link_id="$(get_subscription_link_id "$link")"
+    scheme="$(url_get_scheme "$link")"
+    transport="$(url_get_query_param "$link" "type")"
+    name="$(get_subscription_link_name "$link")"
+    source_name="Subscription $source_index"
+
+    jq -cn \
+        --arg id "$link_id" \
+        --arg name "$name" \
+        --arg protocol "$scheme" \
+        --arg transport "$transport" \
+        --arg reason "$reason" \
+        --arg sourceName "$source_name" \
+        --argjson sourceIndex "$source_index" \
+        --argjson supported "$supported" \
+        --argjson enabled "$enabled" \
+        '{
+            id: $id,
+            name: $name,
+            protocol: $protocol,
+            transport: $transport,
+            sourceIndex: $sourceIndex,
+            sourceName: $sourceName,
+            supported: $supported,
+            enabled: $enabled,
+            reason: $reason
+        }' >> "$SUBSCRIPTION_ITEMS_FILE"
+}
+
+filter_working_subscription_proxy_links() {
+    local section="$1"
+    local source_file="$2"
+    local output_file="$3"
+    local all_output_file="$4"
+    local skipped_file="$5"
+    local items_file="$6"
+    local excluded_ids_file="$7"
+    local source_index="$8"
+    local udp_over_tcp validation_config candidate_config link link_id i valid_links skipped_links skip_reason
+
+    config_get udp_over_tcp "$section" "enable_udp_over_tcp"
+    validation_config='{"outbounds":[]}'
+    valid_links=0
+    skipped_links=0
+    i=1
+
+    : > "$output_file"
+    : > "$all_output_file"
+    : > "$skipped_file"
+    : > "$items_file"
+    SUBSCRIPTION_SKIPPED_LINKS_FILE="$skipped_file"
+    SUBSCRIPTION_ITEMS_FILE="$items_file"
+    while IFS= read -r link || [ -n "$link" ]; do
+        [ -n "$link" ] || continue
+
+        if skip_reason="$(get_subscription_proxy_skip_reason "$link")"; then
+            append_subscription_skipped_proxy_link "$link" "$skip_reason"
+            append_subscription_item "$link" "$source_index" "false" "false" "$skip_reason"
+            skipped_links=$((skipped_links + 1))
+            i=$((i + 1))
+            continue
+        fi
+
+        if candidate_config="$(sing_box_cf_add_proxy_outbound "$validation_config" "$section-subscription-check-$i" \
+            "$link" "$udp_over_tcp")" && [ -n "$candidate_config" ]; then
+            link_id="$(get_subscription_link_id "$link")"
+            printf '%s\n' "$link" >> "$all_output_file"
+            validation_config="$candidate_config"
+            valid_links=$((valid_links + 1))
+            if is_subscription_link_id_excluded "$link_id" "$excluded_ids_file"; then
+                append_subscription_item "$link" "$source_index" "true" "false" "user_excluded"
+            else
+                printf '%s\n' "$link" >> "$output_file"
+                append_subscription_item "$link" "$source_index" "true" "true" ""
+            fi
+        else
+            append_subscription_skipped_proxy_link "$link" "invalid_config"
+            append_subscription_item "$link" "$source_index" "false" "false" "invalid_config"
+            skipped_links=$((skipped_links + 1))
+        fi
+
+        i=$((i + 1))
+    done < "$source_file"
+
+    if [ "$skipped_links" -gt 0 ]; then
+        log "Skipped $skipped_links unsupported subscription proxy links for section '$section'" "warn"
+    fi
+
+    [ "$valid_links" -gt 0 ]
+}
+
+download_subscription_to_file() {
+    local url="$1"
+    local filepath="$2"
+    local http_proxy_address="$3"
+    local retries="${4:-3}"
+    local wait="${5:-2}"
+    local attempt
+
+    for attempt in $(seq 1 "$retries"); do
+        if command -v curl > /dev/null 2>&1; then
+            if [ -n "$http_proxy_address" ]; then
+                curl -fsSL -x "http://$http_proxy_address" --connect-timeout 10 -m 30 -o "$filepath" "$url" &&
+                    [ -s "$filepath" ] && return 0
+            else
+                curl -fsSL --connect-timeout 10 -m 30 -o "$filepath" "$url" && [ -s "$filepath" ] && return 0
+            fi
+        else
+            if [ -n "$http_proxy_address" ]; then
+                http_proxy="http://$http_proxy_address" https_proxy="http://$http_proxy_address" wget -O "$filepath" "$url" &&
+                    [ -s "$filepath" ] && return 0
+            else
+                wget -O "$filepath" "$url" && [ -s "$filepath" ] && return 0
+            fi
+        fi
+
+        log "Attempt $attempt/$retries to download subscription failed" "warn"
+        sleep "$wait"
+    done
+
+    return 1
+}
+
+refresh_subscription_cache() {
+    local section="$1"
+    local subscription_url cache_path all_cache_path skipped_cache_path items_cache_path tmpfile links_file \
+        validated_links_file all_links_file skipped_links_file items_file merged_links_file deduped_links_file \
+        merged_all_links_file deduped_all_links_file merged_skipped_links_file deduped_skipped_links_file \
+        merged_items_file deduped_items_file excluded_ids_file urls_file tmp_cache tmp_all_cache tmp_skipped_cache \
+        tmp_items_cache http_proxy_address failed_sources skipped_sources skipped_json items_json source_index
+
+    SUBSCRIPTION_CACHE_CHANGED=0
+    urls_file="$(mktemp)"
+    merged_links_file="$(mktemp)"
+    deduped_links_file="$(mktemp)"
+    merged_all_links_file="$(mktemp)"
+    deduped_all_links_file="$(mktemp)"
+    merged_skipped_links_file="$(mktemp)"
+    deduped_skipped_links_file="$(mktemp)"
+    merged_items_file="$(mktemp)"
+    deduped_items_file="$(mktemp)"
+    excluded_ids_file="$(mktemp)"
+    if ! collect_subscription_urls "$section" "$urls_file"; then
+        log "Subscription URL is not set for section '$section'" "error"
+        rm -f "$urls_file" "$merged_links_file" "$deduped_links_file" "$merged_all_links_file" \
+            "$deduped_all_links_file" "$merged_skipped_links_file" "$deduped_skipped_links_file" \
+            "$merged_items_file" "$deduped_items_file" "$excluded_ids_file"
+        return 1
+    fi
+
+    collect_subscription_excluded_ids "$section" "$excluded_ids_file"
+    http_proxy_address="$(get_service_proxy_address)"
+    failed_sources=0
+    skipped_sources=0
+    source_index=1
+    : > "$merged_links_file"
+    : > "$merged_all_links_file"
+    : > "$merged_skipped_links_file"
+    : > "$merged_items_file"
+
+    while IFS= read -r subscription_url || [ -n "$subscription_url" ]; do
+        [ -n "$subscription_url" ] || continue
+        case "$subscription_url" in
+        http://* | https://*) ;;
+        *)
+            log "Skipping subscription source with unsupported URL scheme in section '$section'" "warn"
+            skipped_sources=$((skipped_sources + 1))
+            source_index=$((source_index + 1))
+            continue
+            ;;
+        esac
+
+        tmpfile="$(mktemp)"
+        links_file="$(mktemp)"
+        validated_links_file="$(mktemp)"
+        all_links_file="$(mktemp)"
+        skipped_links_file="$(mktemp)"
+        items_file="$(mktemp)"
+
+        if ! download_subscription_to_file "$subscription_url" "$tmpfile" "$http_proxy_address"; then
+            log "Subscription download failed for one of section '$section' sources" "warn"
+            failed_sources=$((failed_sources + 1))
+            rm -f "$tmpfile" "$links_file" "$validated_links_file" "$all_links_file" "$skipped_links_file" \
+                "$items_file"
+            break
+        fi
+
+        if ! normalize_subscription_file "$tmpfile" "$links_file"; then
+            log "One subscription source for section '$section' does not contain supported proxy links" "warn"
+            skipped_sources=$((skipped_sources + 1))
+            rm -f "$tmpfile" "$links_file" "$validated_links_file" "$all_links_file" "$skipped_links_file" \
+                "$items_file"
+            source_index=$((source_index + 1))
+            continue
+        fi
+
+        if ! filter_working_subscription_proxy_links "$section" "$links_file" "$validated_links_file" \
+            "$all_links_file" "$skipped_links_file" "$items_file" "$excluded_ids_file" "$source_index"; then
+            log "One subscription source for section '$section' does not contain proxy links supported by podkop" "warn"
+            skipped_sources=$((skipped_sources + 1))
+            cat "$skipped_links_file" >> "$merged_skipped_links_file"
+            cat "$items_file" >> "$merged_items_file"
+            rm -f "$tmpfile" "$links_file" "$validated_links_file" "$all_links_file" "$skipped_links_file" \
+                "$items_file"
+            source_index=$((source_index + 1))
+            continue
+        fi
+
+        cat "$validated_links_file" >> "$merged_links_file"
+        cat "$all_links_file" >> "$merged_all_links_file"
+        cat "$skipped_links_file" >> "$merged_skipped_links_file"
+        cat "$items_file" >> "$merged_items_file"
+        rm -f "$tmpfile" "$links_file" "$validated_links_file" "$all_links_file" "$skipped_links_file" \
+            "$items_file"
+        source_index=$((source_index + 1))
+    done < "$urls_file"
+
+    if [ "$failed_sources" -gt 0 ]; then
+        rm -f "$urls_file" "$merged_links_file" "$deduped_links_file" "$merged_all_links_file" \
+            "$deduped_all_links_file" "$merged_skipped_links_file" "$deduped_skipped_links_file" \
+            "$merged_items_file" "$deduped_items_file" "$excluded_ids_file"
+        return 1
+    fi
+
+    awk '!seen[$0]++' "$merged_links_file" > "$deduped_links_file"
+    awk '!seen[$0]++' "$merged_all_links_file" > "$deduped_all_links_file"
+    awk '!seen[$0]++' "$merged_skipped_links_file" > "$deduped_skipped_links_file"
+    awk '!seen[$0]++' "$merged_items_file" > "$deduped_items_file"
+    if [ ! -s "$deduped_links_file" ]; then
+        log "Subscriptions for section '$section' do not contain enabled proxy links supported by podkop" "warn"
+        rm -f "$urls_file" "$merged_links_file" "$deduped_links_file" "$merged_all_links_file" \
+            "$deduped_all_links_file" "$merged_skipped_links_file" "$deduped_skipped_links_file" \
+            "$merged_items_file" "$deduped_items_file" "$excluded_ids_file"
+        return 1
+    fi
+
+    if ! mkdir -p "$SUBSCRIPTION_CACHE_DIR"; then
+        log "Failed to create subscription cache directory '$SUBSCRIPTION_CACHE_DIR'" "error"
+        rm -f "$urls_file" "$merged_links_file" "$deduped_links_file" "$merged_all_links_file" \
+            "$deduped_all_links_file" "$merged_skipped_links_file" "$deduped_skipped_links_file" \
+            "$merged_items_file" "$deduped_items_file" "$excluded_ids_file"
+        return 1
+    fi
+
+    cache_path="$(get_subscription_cache_path "$section")"
+    all_cache_path="$(get_subscription_all_cache_path "$section")"
+    skipped_cache_path="$(get_subscription_skipped_cache_path "$section")"
+    items_cache_path="$(get_subscription_items_cache_path "$section")"
+
+    if [ -s "$deduped_skipped_links_file" ]; then
+        skipped_json="$(jq -s '.' "$deduped_skipped_links_file")"
+    else
+        skipped_json="[]"
+    fi
+
+    if [ -s "$deduped_items_file" ]; then
+        items_json="$(jq -s '.' "$deduped_items_file")"
+    else
+        items_json="[]"
+    fi
+
+    if [ ! -f "$cache_path" ] || ! cmp -s "$deduped_links_file" "$cache_path"; then
+        tmp_cache="$cache_path.tmp.$$"
+        if cp "$deduped_links_file" "$tmp_cache" && mv "$tmp_cache" "$cache_path"; then
+            chmod 600 "$cache_path" 2> /dev/null
+            SUBSCRIPTION_CACHE_CHANGED=1
+            log "Subscription cache updated for section '$section'" "info"
+        else
+            rm -f "$tmp_cache" "$urls_file" "$merged_links_file" "$deduped_links_file" "$merged_all_links_file" \
+                "$deduped_all_links_file" "$merged_skipped_links_file" "$deduped_skipped_links_file" \
+                "$merged_items_file" "$deduped_items_file" "$excluded_ids_file"
+            log "Failed to update subscription cache for section '$section'" "error"
+            return 1
+        fi
+    fi
+
+    tmp_all_cache="$all_cache_path.tmp.$$"
+    if cp "$deduped_all_links_file" "$tmp_all_cache" && mv "$tmp_all_cache" "$all_cache_path"; then
+        chmod 600 "$all_cache_path" 2> /dev/null
+    else
+        rm -f "$tmp_all_cache"
+        log "Failed to update full subscription links cache for section '$section'" "warn"
+    fi
+
+    tmp_skipped_cache="$skipped_cache_path.tmp.$$"
+    if printf '%s\n' "$skipped_json" > "$tmp_skipped_cache" && mv "$tmp_skipped_cache" "$skipped_cache_path"; then
+        chmod 600 "$skipped_cache_path" 2> /dev/null
+    else
+        rm -f "$tmp_skipped_cache"
+        log "Failed to update skipped subscription links cache for section '$section'" "warn"
+    fi
+
+    tmp_items_cache="$items_cache_path.tmp.$$"
+    if printf '%s\n' "$items_json" > "$tmp_items_cache" && mv "$tmp_items_cache" "$items_cache_path"; then
+        chmod 600 "$items_cache_path" 2> /dev/null
+    else
+        rm -f "$tmp_items_cache"
+        log "Failed to update subscription items cache for section '$section'" "warn"
+    fi
+
+    if [ "$skipped_sources" -gt 0 ]; then
+        log "Skipped $skipped_sources subscription sources without podkop-compatible links for section '$section'" "warn"
+    fi
+
+    rm -f "$urls_file" "$merged_links_file" "$deduped_links_file" "$merged_all_links_file" \
+        "$deduped_all_links_file" "$merged_skipped_links_file" "$deduped_skipped_links_file" \
+        "$merged_items_file" "$deduped_items_file" "$excluded_ids_file"
+    return 0
+}
+
+load_subscription_proxy_links_for_section() {
+    local section="$1"
+    local output_file="$2"
+    local cache_path
+
+    if ! refresh_subscription_cache "$section"; then
+        log "Using cached subscription for section '$section'" "warn"
+    fi
+
+    cache_path="$(get_subscription_cache_path "$section")"
+    if [ -s "$cache_path" ]; then
+        if cp "$cache_path" "$output_file"; then
+            return 0
+        fi
+
+        log "Failed to read subscription cache for section '$section'" "error"
+        return 1
+    fi
+
+    log "Subscription cache is not available for section '$section'" "fatal"
+    return 1
+}
+
+get_subscription_cached_links() {
+    local section="$1"
+    local cache_path
+
+    if [ -z "$section" ]; then
+        echo "[]"
+        return 1
+    fi
+
+    cache_path="$(get_subscription_cache_path "$section")"
+    if [ ! -s "$cache_path" ]; then
+        echo "[]"
+        return 0
+    fi
+
+    jq -R -s 'split("\n") | map(select(length > 0))' "$cache_path"
+}
+
+get_subscription_skipped_links() {
+    local section="$1"
+    local cache_path
+
+    if [ -z "$section" ]; then
+        echo "[]"
+        return 1
+    fi
+
+    cache_path="$(get_subscription_skipped_cache_path "$section")"
+    if [ ! -s "$cache_path" ]; then
+        echo "[]"
+        return 0
+    fi
+
+    cat "$cache_path"
+}
+
+get_subscription_items() {
+    local section="$1"
+    local cache_path
+
+    if [ -z "$section" ]; then
+        echo "[]"
+        return 1
+    fi
+
+    cache_path="$(get_subscription_items_cache_path "$section")"
+    if [ ! -s "$cache_path" ]; then
+        refresh_subscription_cache "$section" > /dev/null 2>&1 || true
+    fi
+
+    if [ ! -s "$cache_path" ]; then
+        echo "[]"
+        return 0
+    fi
+
+    cat "$cache_path"
+}
+
+validate_subscription_link_id() {
+    local link_id="$1"
+
+    if [ "${#link_id}" -ne 32 ]; then
+        return 1
+    fi
+
+    case "$link_id" in
+    *[!A-Fa-f0-9]*) return 1 ;;
+    esac
+
+    return 0
+}
+
+validate_subscription_section_name() {
+    local section="$1"
+
+    case "$section" in
+    "" | *[!A-Za-z0-9_-]*) return 1 ;;
+    esac
+
+    return 0
+}
+
+apply_subscription_exclusions_to_cached_links() {
+    local section="$1"
+    local cache_path all_cache_path items_cache_path excluded_ids_file active_links_file tmp_cache tmp_items_cache \
+        excluded_ids_json link link_id items_json
+
+    SUBSCRIPTION_CACHE_CHANGED=0
+    cache_path="$(get_subscription_cache_path "$section")"
+    all_cache_path="$(get_subscription_all_cache_path "$section")"
+    items_cache_path="$(get_subscription_items_cache_path "$section")"
+    excluded_ids_file="$(mktemp)"
+    active_links_file="$(mktemp)"
+
+    if [ ! -s "$all_cache_path" ] && [ -s "$cache_path" ]; then
+        cp "$cache_path" "$all_cache_path"
+        chmod 600 "$all_cache_path" 2> /dev/null
+    fi
+
+    if [ ! -s "$all_cache_path" ]; then
+        rm -f "$excluded_ids_file" "$active_links_file"
+        return 1
+    fi
+
+    collect_subscription_excluded_ids "$section" "$excluded_ids_file"
+    : > "$active_links_file"
+
+    while IFS= read -r link || [ -n "$link" ]; do
+        [ -n "$link" ] || continue
+        link_id="$(get_subscription_link_id "$link")"
+        if ! is_subscription_link_id_excluded "$link_id" "$excluded_ids_file"; then
+            printf '%s\n' "$link" >> "$active_links_file"
+        fi
+    done < "$all_cache_path"
+
+    if [ ! -s "$active_links_file" ]; then
+        rm -f "$excluded_ids_file" "$active_links_file"
+        return 1
+    fi
+
+    if [ ! -f "$cache_path" ] || ! cmp -s "$active_links_file" "$cache_path"; then
+        tmp_cache="$cache_path.tmp.$$"
+        if cp "$active_links_file" "$tmp_cache" && mv "$tmp_cache" "$cache_path"; then
+            chmod 600 "$cache_path" 2> /dev/null
+            SUBSCRIPTION_CACHE_CHANGED=1
+        else
+            rm -f "$tmp_cache" "$excluded_ids_file" "$active_links_file"
+            return 1
+        fi
+    fi
+
+    if [ -s "$items_cache_path" ]; then
+        excluded_ids_json="$(jq -R -s -c 'split("\n") | map(select(length > 0))' "$excluded_ids_file")"
+        tmp_items_cache="$items_cache_path.tmp.$$"
+        items_json="$(jq -c --argjson excludedIds "$excluded_ids_json" '
+            map(
+                if .supported == true then
+                    . as $item
+                    | .enabled = (($excludedIds | index($item.id)) == null)
+                    | .reason = (if (($excludedIds | index($item.id)) == null) then "" else "user_excluded" end)
+                else
+                    .
+                end
+            )
+        ' "$items_cache_path")"
+        if printf '%s\n' "$items_json" > "$tmp_items_cache" && mv "$tmp_items_cache" "$items_cache_path"; then
+            chmod 600 "$items_cache_path" 2> /dev/null
+        else
+            rm -f "$tmp_items_cache"
+            log "Failed to update subscription items cache for section '$section'" "warn"
+        fi
+    fi
+
+    rm -f "$excluded_ids_file" "$active_links_file"
+    return 0
+}
+
+set_subscription_link_enabled() {
+    local section="$1"
+    local link_id="$2"
+    local enabled="$3"
+    local connection_type proxy_config_type items_cache_path remaining_enabled_count
+
+    if ! validate_subscription_section_name "$section" || ! validate_subscription_link_id "$link_id"; then
+        echo '{"success":false,"error":"invalid_arguments"}'
+        return 1
+    fi
+
+    case "$enabled" in
+    1 | true | on | enabled) enabled=1 ;;
+    0 | false | off | disabled) enabled=0 ;;
+    *)
+        echo '{"success":false,"error":"invalid_enabled_value"}'
+        return 1
+        ;;
+    esac
+
+    config_get connection_type "$section" "connection_type"
+    config_get proxy_config_type "$section" "proxy_config_type"
+    if [ "$connection_type" != "proxy" ] || [ "$proxy_config_type" != "subscription_urltest" ]; then
+        echo '{"success":false,"error":"section_is_not_subscription_urltest"}'
+        return 1
+    fi
+
+    if [ "$enabled" -eq 0 ]; then
+        items_cache_path="$(get_subscription_items_cache_path "$section")"
+        if [ ! -s "$items_cache_path" ]; then
+            refresh_subscription_cache "$section" > /dev/null 2>&1 || true
+        fi
+
+        remaining_enabled_count="$(jq --arg id "$link_id" '
+            [.[] | select(.supported == true and .enabled == true and .id != $id)] | length
+        ' "$items_cache_path" 2> /dev/null || echo 0)"
+        if [ "$remaining_enabled_count" -eq 0 ]; then
+            echo '{"success":false,"error":"cannot_disable_last_enabled_link"}'
+            return 1
+        fi
+    fi
+
+    uci -q del_list "podkop.$section.subscription_excluded_link_ids=$link_id"
+    if [ "$enabled" -eq 0 ]; then
+        uci -q add_list "podkop.$section.subscription_excluded_link_ids=$link_id"
+    fi
+
+    if ! uci commit podkop; then
+        echo '{"success":false,"error":"uci_commit_failed"}'
+        return 1
+    fi
+
+    config_load "$PODKOP_CONFIG"
+    if ! apply_subscription_exclusions_to_cached_links "$section"; then
+        if ! refresh_subscription_cache "$section" > /dev/null 2>&1; then
+            echo '{"success":false,"error":"subscription_cache_update_failed"}'
+            return 1
+        fi
+    fi
+
+    if [ "$SUBSCRIPTION_CACHE_CHANGED" -eq 1 ]; then
+        if ! /etc/init.d/podkop reload > /dev/null 2>&1; then
+            echo '{"success":false,"error":"reload_failed"}'
+            return 1
+        fi
+    fi
+
+    echo '{"success":true}'
+}
+
+subscription_update_section_handler() {
+    local section="$1"
+    local connection_type proxy_config_type
+
+    if [ -n "$SUBSCRIPTION_UPDATE_TARGET" ] && [ "$SUBSCRIPTION_UPDATE_TARGET" != "$section" ]; then
+        return 0
+    fi
+
+    config_get connection_type "$section" "connection_type"
+    config_get proxy_config_type "$section" "proxy_config_type"
+
+    if [ "$connection_type" != "proxy" ] || [ "$proxy_config_type" != "subscription_urltest" ] ||
+        ! section_has_subscription_urls "$section"; then
+        return 0
+    fi
+
