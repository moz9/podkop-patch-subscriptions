+  return E(
+    "details",
+    {
+      class: "pdk-dns-optimizer__history",
+      open: dnsOptimizerState.historyOpen || undefined,
+      toggle: (event) => {
+        dnsOptimizerState.historyOpen = Boolean(event.currentTarget?.open);
+      },
+    },
+    [
+      E("summary", {}, label),
+      renderMainResults(status, running),
+      renderBootstrapResults(status),
+    ],
+  );
