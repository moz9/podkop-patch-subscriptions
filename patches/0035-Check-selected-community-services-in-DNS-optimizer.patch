+        unstable="$(awk -F '|' -v service="$service" '
+            NR == FNR { successes[$0]++; next }
+            $1 == "community" && $2 == service && successes[$1 "|" $2 "|" $3] == 1 { print $3 }
+        ' "$successful_file" "$probes_file" | jq -Rsc 'split("\n") | map(select(length > 0))')"
+        tested=true
+        passed=false
+        stable=false
+        [ "$passed_domains" -eq "$total_domains" ] && passed=true
+        [ "$stable_domains" -eq "$total_domains" ] && stable=true
+        jq -cn \
+            --arg id "$service" \
+            --argjson tested "$tested" \
+            --argjson passed "$passed" \
+            --argjson stable "$stable" \
+            --argjson passedDomains "$passed_domains" \
+            --argjson stableDomains "$stable_domains" \
+            --argjson totalDomains "$total_domains" \
+            --argjson failures "$failures" \
+            --argjson unstable "$unstable" \
+            '{id:$id,tested:$tested,passed:$passed,stable:$stable,passedDomains:$passedDomains,stableDomains:$stableDomains,totalDomains:$totalDomains,failures:$failures,unstable:$unstable}' \
+            >> "$output_file"
+    done < "$selected_file"
