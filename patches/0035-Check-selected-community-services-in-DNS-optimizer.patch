+write_selected_community_services() {
+    local file="$1"
+    local sections_file sorted_file line key value section connection_type values
+
+    : > "$file"
+    sections_file="$(mktemp)"
+    uci -q show podkop 2> /dev/null |
+        while IFS= read -r line; do
+            case "$line" in
+                podkop.*.connection_type=*) ;;
+                *) continue ;;
+            esac
+
+            key="${line%%=*}"
+            value="${line#*=}"
+            value="${value#\'}"
+            value="${value%\'}"
+            section="${key#podkop.}"
+            section="${section%.connection_type}"
+            case "$value" in
+                proxy|vpn) printf '%s\n' "$section" ;;
+            esac
+        done > "$sections_file"
+
+    while IFS= read -r section; do
+        [ -n "$section" ] || continue
+        connection_type="$(uci -q get "podkop.$section.connection_type" 2> /dev/null || true)"
+        case "$connection_type" in
+            proxy|vpn) ;;
+            *) continue ;;
+        esac
+        values="$(uci -q get "podkop.$section.community_lists" 2> /dev/null || true)"
+        for value in $values; do
+            [ -n "$value" ] || continue
+            grep -Fxq "$value" "$file" 2> /dev/null || printf '%s\n' "$value" >> "$file"
+        done
+    done < "$sections_file"
+
+    rm -f "$sections_file"
+    sorted_file="$(mktemp)"
+    if sort -u "$file" > "$sorted_file" 2> /dev/null; then
+        mv "$sorted_file" "$file"
+    else
+        rm -f "$sorted_file"
+    fi
+}
