+    : > "$output_file"
+    while IFS= read -r service; do
+        [ -n "$service" ] || continue
+        total_domains="$(awk -F '|' -v service="$service" '$1 == "community" && $2 == service { total++ } END { print total + 0 }' "$probes_file")"
