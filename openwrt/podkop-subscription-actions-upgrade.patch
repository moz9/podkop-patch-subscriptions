diff --git a/usr/bin/podkop b/usr/bin/podkop
index 3dff359..826ea64 100644
--- a/usr/bin/podkop
+++ b/usr/bin/podkop
@@ -1573,6 +1573,313 @@ subscription_update() {
     echolog "Subscription update completed, no changes"
 }
 
+subscription_update_json() {
+    local section="$1"
+    local output status success
+
+    output="$(subscription_update "$section" 2>&1)"
+    status=$?
+    if [ "$status" -eq 0 ]; then
+        success=true
+    else
+        success=false
+    fi
+
+    jq -cn --argjson success "$success" --arg output "$output" --argjson status "$status" \
+        '{success:$success, status:$status, output:$output}'
+}
+
+get_clash_api_base_url() {
+    local clash_api_controller_address
+
+    clash_api_controller_address="$(get_service_listen_address)"
+    if [ -z "$clash_api_controller_address" ]; then
+        clash_api_controller_address="127.0.0.1"
+    fi
+
+    echo "$clash_api_controller_address:$SB_CLASH_API_CONTROLLER_PORT"
+}
+
+get_clash_api_auth_header() {
+    local enable_yacd_wan_access yacd_secret_key
+
+    config_get_bool enable_yacd_wan_access "settings" "enable_yacd_wan_access" 0
+    config_get yacd_secret_key "settings" "yacd_secret_key"
+
+    if [ "$enable_yacd_wan_access" -eq 1 ]; then
+        echo "Authorization: Bearer $yacd_secret_key"
+    fi
+}
+
+clash_api_get_proxy_now() {
+    local clash_url="$1"
+    local auth_header="$2"
+    local proxy_tag="$3"
+
+    curl -s --header "$auth_header" "$clash_url/proxies/$proxy_tag" | jq -r '.now // ""'
+}
+
+clash_api_set_group_proxy_raw() {
+    local clash_url="$1"
+    local auth_header="$2"
+    local group_tag="$3"
+    local proxy_tag="$4"
+    local response http_code
+
+    response=$(
+        curl -X PUT -s -w "\n%{http_code}" "$clash_url/proxies/$group_tag" \
+            --header "$auth_header" \
+            --data-raw "{\"name\":\"$proxy_tag\"}"
+    )
+    http_code="$(echo "$response" | tail -n 1)"
+
+    [ "$http_code" = "204" ]
+}
+
+get_subscription_benchmark_port() {
+    echo "42080"
+}
+
+subscription_speedtest_restore_mixed_proxy() {
+    local section="$1"
+    local original_mixed_enabled="$2"
+    local original_mixed_port="$3"
+    local mixed_changed="$4"
+
+    [ "$mixed_changed" -eq 1 ] || return 0
+
+    if [ -n "$original_mixed_enabled" ]; then
+        uci -q set "podkop.$section.mixed_proxy_enabled=$original_mixed_enabled"
+    else
+        uci -q delete "podkop.$section.mixed_proxy_enabled"
+    fi
+
+    if [ -n "$original_mixed_port" ]; then
+        uci -q set "podkop.$section.mixed_proxy_port=$original_mixed_port"
+    else
+        uci -q delete "podkop.$section.mixed_proxy_port"
+    fi
+
+    uci commit podkop > /dev/null 2>&1 || return 1
+    config_load "$PODKOP_CONFIG"
+    /etc/init.d/podkop reload > /dev/null 2>&1
+}
+
+subscription_speedtest_result_error() {
+    local id="$1"
+    local tag="$2"
+    local name="$3"
+    local error="$4"
+
+    jq -cn --arg id "$id" --arg tag "$tag" --arg name "$name" --arg error "$error" \
+        '{id:$id, tag:$tag, name:$name, success:false, error:$error}'
+}
+
+subscription_speedtest_result_success() {
+    local id="$1"
+    local tag="$2"
+    local name="$3"
+    local bytes_per_second="$4"
+    local time_total="$5"
+    local size_download="$6"
+    local http_code="$7"
+
+    jq -cn --arg id "$id" --arg tag "$tag" --arg name "$name" \
+        --argjson bytesPerSecond "$bytes_per_second" \
+        --argjson timeTotal "$time_total" \
+        --argjson sizeDownload "$size_download" \
+        --argjson httpCode "$http_code" \
+        '{id:$id, tag:$tag, name:$name, success:true, bytesPerSecond:$bytesPerSecond, timeTotal:$timeTotal, sizeDownload:$sizeDownload, httpCode:$httpCode}'
+}
+
+subscription_speedtest() {
+    local section="$1"
+    local items_cache_path active_items_file results_file clash_url auth_header selector_tag original_proxy \
+        original_mixed_enabled original_mixed_port mixed_port mixed_changed mixed_address benchmark_url \
+        item_json id name tag index output bytes_per_second time_total size_download http_code results_json
+
+    if [ -z "$section" ]; then
+        echo '{"success":false,"error":"section_required"}'
+        return 1
+    fi
+
+    if ! validate_subscription_urltest_section "$section"; then
+        echo '{"success":false,"error":"section_is_not_subscription_urltest"}'
+        return 1
+    fi
+
+    items_cache_path="$(get_subscription_items_cache_path "$section")"
+    if [ ! -s "$items_cache_path" ]; then
+        refresh_subscription_cache "$section" > /dev/null 2>&1 || true
+    fi
+
+    if [ ! -s "$items_cache_path" ]; then
+        echo '{"success":false,"error":"subscription_cache_missing"}'
+        return 1
+    fi
+
+    active_items_file="$(mktemp)"
+    results_file="$(mktemp)"
+    jq -c '.[] | select(.supported == true and .enabled == true)' "$items_cache_path" > "$active_items_file"
+
+    if [ ! -s "$active_items_file" ]; then
+        rm -f "$active_items_file" "$results_file"
+        echo '{"success":false,"error":"no_enabled_links"}'
+        return 1
+    fi
+
+    clash_url="$(get_clash_api_base_url)"
+    auth_header="$(get_clash_api_auth_header)"
+    selector_tag="$(get_outbound_tag_by_section "$section")"
+    original_proxy="$(clash_api_get_proxy_now "$clash_url" "$auth_header" "$selector_tag")"
+
+    if [ -z "$original_proxy" ]; then
+        rm -f "$active_items_file" "$results_file"
+        echo '{"success":false,"error":"selector_not_available"}'
+        return 1
+    fi
+
+    config_get original_mixed_enabled "$section" "mixed_proxy_enabled"
+    config_get original_mixed_port "$section" "mixed_proxy_port"
+    mixed_port="$original_mixed_port"
+    [ -n "$mixed_port" ] || mixed_port="$(get_subscription_benchmark_port "$section")"
+    mixed_changed=0
+
+    if [ "$original_mixed_enabled" != "1" ] || [ -z "$original_mixed_port" ]; then
+        uci -q set "podkop.$section.mixed_proxy_enabled=1"
+        uci -q set "podkop.$section.mixed_proxy_port=$mixed_port"
+        if ! uci commit podkop > /dev/null 2>&1; then
+            rm -f "$active_items_file" "$results_file"
+            echo '{"success":false,"error":"uci_commit_failed"}'
+            return 1
+        fi
+        config_load "$PODKOP_CONFIG"
+        mixed_changed=1
+
+        if ! /etc/init.d/podkop reload > /dev/null 2>&1; then
+            subscription_speedtest_restore_mixed_proxy "$section" "$original_mixed_enabled" "$original_mixed_port" "$mixed_changed" > /dev/null 2>&1
+            rm -f "$active_items_file" "$results_file"
+            echo '{"success":false,"error":"reload_failed"}'
+            return 1
+        fi
+    fi
+
+    mixed_address="$(get_service_listen_address)"
+    if [ -z "$mixed_address" ]; then
+        clash_api_set_group_proxy_raw "$clash_url" "$auth_header" "$selector_tag" "$original_proxy" > /dev/null 2>&1 || true
+        subscription_speedtest_restore_mixed_proxy "$section" "$original_mixed_enabled" "$original_mixed_port" "$mixed_changed" > /dev/null 2>&1
+        rm -f "$active_items_file" "$results_file"
+        echo '{"success":false,"error":"mixed_proxy_address_missing"}'
+        return 1
+    fi
+
+    benchmark_url="https://speed.cloudflare.com/__down?bytes=1048576"
+    index=1
+    while IFS= read -r item_json || [ -n "$item_json" ]; do
+        [ -n "$item_json" ] || continue
+
+        id="$(echo "$item_json" | jq -r '.id')"
+        name="$(echo "$item_json" | jq -r '.name // ""')"
+        tag="$(get_outbound_tag_by_section "$section-$index")"
+
+        if ! clash_api_set_group_proxy_raw "$clash_url" "$auth_header" "$selector_tag" "$tag"; then
+            subscription_speedtest_result_error "$id" "$tag" "$name" "select_failed" >> "$results_file"
+            index=$((index + 1))
+            continue
+        fi
+
+        sleep 1
+        output="$(
+            curl -L -s -o /dev/null \
+                -x "http://$mixed_address:$mixed_port" \
+                --connect-timeout 8 \
+                -m 20 \
+                -w '%{speed_download} %{time_total} %{size_download} %{http_code}' \
+                "$benchmark_url" 2> /dev/null
+        )"
+
+        bytes_per_second="$(echo "$output" | awk '{printf "%d", $1}')"
+        time_total="$(echo "$output" | awk '{print ($2 == "" ? 0 : $2)}')"
+        size_download="$(echo "$output" | awk '{printf "%d", $3}')"
+        http_code="$(echo "$output" | awk '{printf "%d", $4}')"
+
+        if [ "${bytes_per_second:-0}" -gt 0 ] && [ "${http_code:-0}" -ge 200 ] && [ "${http_code:-0}" -lt 400 ]; then
+            subscription_speedtest_result_success "$id" "$tag" "$name" \
+                "${bytes_per_second:-0}" "${time_total:-0}" "${size_download:-0}" "${http_code:-0}" >> "$results_file"
+        else
+            subscription_speedtest_result_error "$id" "$tag" "$name" "download_failed" >> "$results_file"
+        fi
+
+        index=$((index + 1))
+    done < "$active_items_file"
+
+    clash_api_set_group_proxy_raw "$clash_url" "$auth_header" "$selector_tag" "$original_proxy" > /dev/null 2>&1 || true
+    subscription_speedtest_restore_mixed_proxy "$section" "$original_mixed_enabled" "$original_mixed_port" "$mixed_changed" > /dev/null 2>&1
+
+    results_json="$(jq -s '.' "$results_file")"
+    rm -f "$active_items_file" "$results_file"
+    jq -cn --arg section "$section" --argjson results "$results_json" \
+        '{success:true, section:$section, results:$results}'
+}
+
+subscription_patch_update_status_file() {
+    echo "/tmp/podkop-subscriptions-patch-update.json"
+}
+
+subscription_patch_update() {
+    local status_file runner
+
+    status_file="$(subscription_patch_update_status_file)"
+    runner="/tmp/podkop-subscriptions-patch-update-runner.sh"
+
+    cat > "$runner" << 'EOF'
+#!/bin/ash
+status_file="/tmp/podkop-subscriptions-patch-update.json"
+log_file="/tmp/podkop-subscriptions-patch-update.log"
+
+write_status() {
+    local state="$1"
+    local message="$2"
+    local log_tail="$3"
+    jq -cn --arg state "$state" --arg message "$message" \
+        --arg updatedAt "$(date -Iseconds 2> /dev/null || date)" \
+        --arg logTail "$log_tail" \
+        '{state:$state, message:$message, updatedAt:$updatedAt, logTail:$logTail}' > "$status_file"
+}
+
+write_status "running" "patch_update_running" ""
+
+tmp="/tmp/podkop-subscriptions-install.sh"
+if ! wget -O "$tmp" "https://raw.githubusercontent.com/moz9/podkop-patch-subscriptions/main/openwrt/install.sh" > "$log_file" 2>&1; then
+    write_status "error" "download_failed" "$(tail -n 20 "$log_file" 2> /dev/null)"
+    exit 1
+fi
+
+if PODKOP_PATCH_VERSION="${PODKOP_PATCH_VERSION:-main}" sh "$tmp" >> "$log_file" 2>&1; then
+    write_status "success" "patch_update_success" "$(tail -n 20 "$log_file" 2> /dev/null)"
+else
+    write_status "error" "install_failed" "$(tail -n 20 "$log_file" 2> /dev/null)"
+    exit 1
+fi
+EOF
+
+    chmod +x "$runner"
+    "$runner" > /dev/null 2>&1 &
+
+    echo '{"success":true,"started":true}'
+}
+
+get_subscription_patch_update_status() {
+    local status_file
+
+    status_file="$(subscription_patch_update_status_file)"
+    if [ -s "$status_file" ]; then
+        cat "$status_file"
+    else
+        echo '{"state":"idle","message":"","updatedAt":"","logTail":""}'
+    fi
+}
+
 # sing-box funcs
 sing_box_configure_service() {
     local sing_box_enabled sing_box_user sing_box_config_path sing_box_conffile
@@ -3755,6 +4062,13 @@ Available commands:
