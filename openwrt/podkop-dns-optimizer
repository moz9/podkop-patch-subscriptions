#!/bin/ash

VERSION="20260711-dns-optimizer-v6"
STATE_DIR="/tmp/podkop-dns-optimizer"
STATUS_FILE="$STATE_DIR/status.json"
LOG_FILE="$STATE_DIR/worker.log"
LOCK_DIR="$STATE_DIR/lock"
PERSIST_DIR="/etc/podkop/dns-optimizer"
PREVIOUS_FILE="$PERSIST_DIR/previous-dns.json"
SELF="$(readlink -f "$0" 2> /dev/null || printf '%s' "$0")"

updated_at() {
    date -Iseconds 2> /dev/null || date
}

ensure_state_dir() {
    mkdir -p "$STATE_DIR"
    chmod 700 "$STATE_DIR" 2> /dev/null || true
}

write_status() {
    local state="$1"
    local action="$2"
    local message="$3"
    local progress="$4"
    local completed="$5"
    local total="$6"
    local pid="$7"
    local tmp

    ensure_state_dir
    tmp="$STATUS_FILE.tmp.$$"
    jq -cn \
        --arg state "$state" \
        --arg action "$action" \
        --arg message "$message" \
        --arg updatedAt "$(updated_at)" \
        --argjson progress "${progress:-0}" \
        --argjson completed "${completed:-0}" \
        --argjson total "${total:-0}" \
        --argjson pid "${pid:-0}" \
        '{state:$state,action:$action,message:$message,progress:$progress,completed:$completed,total:$total,pid:$pid,updatedAt:$updatedAt}' \
        > "$tmp" && mv "$tmp" "$STATUS_FILE"
    chmod 600 "$STATUS_FILE" 2> /dev/null || true
}

write_final_status() {
    local source_file="$1"
    local tmp

    ensure_state_dir
    tmp="$STATUS_FILE.tmp.$$"
    cp "$source_file" "$tmp" && mv "$tmp" "$STATUS_FILE"
    chmod 600 "$STATUS_FILE" 2> /dev/null || true
}

is_ipv4() {
    echo "$1" | awk -F. '
        NF != 4 { exit 1 }
        {
            for (i = 1; i <= 4; i++) {
                if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) exit 1
            }
        }
    '
}

candidate_host() {
    local value="$1"
    value="${value%%/*}"
    value="${value%%:*}"
    printf '%s\n' "$value"
}

candidate_path() {
    local value="$1"
    case "$value" in
        */*) printf '/%s\n' "${value#*/}" ;;
        *) printf '/dns-query\n' ;;
    esac
}

append_unique_candidate() {
    local file="$1"
    local id="$2"
    local provider="$3"
    local value="$4"
    local profile="$5"

    [ -n "$value" ] || return 0
    if awk -F '|' -v value="$value" '$3 == value { found = 1 } END { exit !found }' "$file"; then
        return 0
    fi
    printf '%s|%s|%s|%s\n' "$id" "$provider" "$value" "$profile" >> "$file"
}

