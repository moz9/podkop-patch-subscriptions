    community_counts="${community_counts#*|}"
    community_probe_stable="${community_counts%%|*}"
    community_probe_total="${community_counts#*|}"
    community_selected="$(wc -l < "$selected_file" | tr -d ' ')"
    selected_community_json="$(jq -Rsc 'split("\n") | map(select(length > 0))' "$selected_file")"
    compatible="$(find_compatible_bootstrap "$bootstrap_json" "$host" "$id" || true)"
    if [ -z "$compatible" ]; then
        build_community_results "$successful_file" "$probes_file" "$selected_file" "$community_results_file" false
        jq -cn \
            --arg id "$id" --arg provider "$provider" --arg dnsServer "$value" --arg profile "$profile" \
            --arg protocol "$protocol" --arg error "bootstrap_failed" --argjson totalQueries "$total" \
            --argjson compatibilityTotal "$compatibility_total" --argjson selectedCommunityServices "$selected_community_json" \
            --argjson communitySelected "$community_selected" --argjson communityProbeTotal "$community_probe_total" \
            --slurpfile communityResults "$community_results_file" \
            '{id:$id,provider:$provider,dnsServer:$dnsServer,profile:$profile,protocol:$protocol,successCount:0,totalQueries:$totalQueries,successRate:0,medianMs:0,p90Ms:0,jitterMs:0,nxdomainOk:false,compatibilityPassed:0,compatibilityStable:0,compatibilityTotal:$compatibilityTotal,compatibilityScore:0,compatibilityFailures:[],compatibilityUnstable:[],selectedCommunityServices:$selectedCommunityServices,communitySelected:$communitySelected,communityTested:0,communityPassed:0,communityStable:0,communityProbePassed:0,communityProbeStable:0,communityProbeTotal:$communityProbeTotal,communityScore:0,communityResults:$communityResults,universalEligible:false,reliable:false,score:-1000000,error:$error}'
        rm -f "$probes_file" "$selected_file" "$successful_file" "$community_results_file"
        return 0
    fi

    bootstrap="${compatible%%|*}"
    compatible="${compatible#*|}"
    endpoint_ip="${compatible%%|*}"
    bootstrap_line="${compatible#*|}"
    bootstrap_provider="$(printf '%s\n' "$bootstrap_line" | jq -r '.provider')"
    bootstrap_median="$(printf '%s\n' "$bootstrap_line" | jq -r '.medianMs')"
    bootstrap_jitter="$(printf '%s\n' "$bootstrap_line" | jq -r '.jitterMs')"

    times="$(mktemp)"
    success=0
    failures=0
    stop_early=0
    if is_ipv4 "$host"; then
        run_dns_query "$protocol" "$endpoint_ip" "" "$path" example.net NOERROR >/dev/null 2>&1 || true
    else
        run_dns_query "$protocol" "$endpoint_ip" "$host" "$path" example.net NOERROR >/dev/null 2>&1 || true
    fi
    for round in 1 2; do
        while IFS='|' read -r scope service domain; do
            [ -n "$domain" ] || continue
            if is_ipv4 "$host"; then
                output="$(run_dns_query "$protocol" "$endpoint_ip" "" "$path" "$domain" NOERROR 2> /dev/null || true)"
            else
                output="$(run_dns_query "$protocol" "$endpoint_ip" "$host" "$path" "$domain" NOERROR 2> /dev/null || true)"
            fi
            if [ -n "$output" ]; then
                printf '%s\n' "$output" >> "$times"
                printf '%s|%s|%s\n' "$scope" "$service" "$domain" >> "$successful_file"
                success=$((success + 1))
            else
                failures=$((failures + 1))
                if [ "$failures" -ge 2 ] && [ "$success" -eq 0 ]; then
                    stop_early=1
                    break
                fi
            fi
        done < "$probes_file"
        [ "$stop_early" -eq 1 ] && break
    done

    nxdomain_ok=false
    if [ "$success" -ge $((total - 1)) ]; then
        if is_ipv4 "$host"; then
            output="$(run_dns_query "$protocol" "$endpoint_ip" "" "$path" "podkop-dns-test.invalid" NXDOMAIN 2> /dev/null || true)"
        else
            output="$(run_dns_query "$protocol" "$endpoint_ip" "$host" "$path" "podkop-dns-test.invalid" NXDOMAIN 2> /dev/null || true)"
        fi
        [ -n "$output" ] && nxdomain_ok=true
    fi

    stats="$(calculate_stats "$times")"
    rm -f "$times"
    median="${stats%%|*}"
    stats="${stats#*|}"
    jitter="${stats%%|*}"
    p90="${stats#*|}"
    success_rate=$((success * 100 / total))
    base_counts="$(calculate_probe_scope_counts base "$successful_file" "$probes_file")"
    compatibility_passed="${base_counts%%|*}"
    base_counts="${base_counts#*|}"
    compatibility_stable="${base_counts%%|*}"
    compatibility_total="${base_counts#*|}"
    community_counts="$(calculate_probe_scope_counts community "$successful_file" "$probes_file")"
    community_probe_passed="${community_counts%%|*}"
    community_counts="${community_counts#*|}"
    community_probe_stable="${community_counts%%|*}"
    community_probe_total="${community_counts#*|}"
    compatibility_score=$(((compatibility_passed * 70 + compatibility_stable * 30) / compatibility_total))
    compatibility_failures="$(awk -F '|' '
        NR == FNR { successes[$0]++; next }
        $1 == "base" && successes[$1 "|" $2 "|" $3] == 0 { print $3 }
    ' "$successful_file" "$probes_file" | jq -Rsc 'split("\n") | map(select(length > 0))')"
    compatibility_unstable="$(awk -F '|' '
        NR == FNR { successes[$0]++; next }
        $1 == "base" && successes[$1 "|" $2 "|" $3] == 1 { print $3 }
    ' "$successful_file" "$probes_file" | jq -Rsc 'split("\n") | map(select(length > 0))')"
    build_community_results "$successful_file" "$probes_file" "$selected_file" "$community_results_file" true
    community_tested="$(jq -s 'map(select(.tested == true)) | length' "$community_results_file")"
    community_passed="$(jq -s 'map(select(.tested == true and .passed == true)) | length' "$community_results_file")"
    community_stable="$(jq -s 'map(select(.tested == true and .stable == true)) | length' "$community_results_file")"
    if [ "$community_probe_total" -gt 0 ]; then
        community_score=$(((community_probe_passed * 70 + community_probe_stable * 30) / community_probe_total))
    else
        community_score=100
    fi
    score=$((compatibility_score * 10000 + community_score * 15000 + success_rate * 1000 - median * 30 - p90 * 12 - jitter * 15 - bootstrap_median * 5))
    reliable=false
    universal_eligible=false
    error=""
    if [ "$success" -ge $((total - 1)) ] \
        && [ "$compatibility_passed" -eq "$compatibility_total" ] \
        && [ "$community_probe_passed" -eq "$community_probe_total" ] \
        && [ "$nxdomain_ok" = true ]; then
        reliable=true
        if profile_is_universal "$profile"; then
            universal_eligible=true
        fi
    elif [ "$success" -ge $((total - 1)) ] && [ "$nxdomain_ok" != true ]; then
        score=$((score - 500000))
        error="nxdomain_check_failed"
    elif [ "$compatibility_passed" -lt "$compatibility_total" ]; then
        error="service_compatibility_failed"
    elif [ "$community_probe_passed" -lt "$community_probe_total" ]; then
        error="community_service_failed"
    else
        error="dns_queries_failed"
    fi

    jq -cn \
        --arg id "$id" --arg provider "$provider" --arg dnsServer "$value" --arg profile "$profile" \
        --arg protocol "$protocol" --arg endpointIp "$endpoint_ip" \
        --arg bootstrapDnsServer "$bootstrap" --arg bootstrapProvider "$bootstrap_provider" --arg error "$error" \
        --argjson successCount "$success" --argjson totalQueries "$total" --argjson successRate "$success_rate" \
        --argjson medianMs "$median" --argjson p90Ms "$p90" --argjson jitterMs "$jitter" \
        --argjson bootstrapMedianMs "$bootstrap_median" --argjson bootstrapJitterMs "$bootstrap_jitter" \
        --argjson compatibilityPassed "$compatibility_passed" --argjson compatibilityTotal "$compatibility_total" \
        --argjson compatibilityStable "$compatibility_stable" --argjson compatibilityScore "$compatibility_score" \
        --argjson compatibilityFailures "$compatibility_failures" --argjson compatibilityUnstable "$compatibility_unstable" \
        --argjson selectedCommunityServices "$selected_community_json" --argjson communitySelected "$community_selected" \
        --argjson communityTested "$community_tested" --argjson communityPassed "$community_passed" --argjson communityStable "$community_stable" \
        --argjson communityProbePassed "$community_probe_passed" --argjson communityProbeStable "$community_probe_stable" \
        --argjson communityProbeTotal "$community_probe_total" --argjson communityScore "$community_score" \
        --argjson nxdomainOk "$nxdomain_ok" --argjson universalEligible "$universal_eligible" --argjson reliable "$reliable" --argjson score "$score" \
        --slurpfile communityResults "$community_results_file" \
        '{id:$id,provider:$provider,dnsServer:$dnsServer,profile:$profile,protocol:$protocol,endpointIp:$endpointIp,bootstrapDnsServer:$bootstrapDnsServer,bootstrapProvider:$bootstrapProvider,bootstrapMedianMs:$bootstrapMedianMs,bootstrapJitterMs:$bootstrapJitterMs,successCount:$successCount,totalQueries:$totalQueries,successRate:$successRate,medianMs:$medianMs,p90Ms:$p90Ms,jitterMs:$jitterMs,nxdomainOk:$nxdomainOk,compatibilityPassed:$compatibilityPassed,compatibilityStable:$compatibilityStable,compatibilityTotal:$compatibilityTotal,compatibilityScore:$compatibilityScore,compatibilityFailures:$compatibilityFailures,compatibilityUnstable:$compatibilityUnstable,selectedCommunityServices:$selectedCommunityServices,communitySelected:$communitySelected,communityTested:$communityTested,communityPassed:$communityPassed,communityStable:$communityStable,communityProbePassed:$communityProbePassed,communityProbeStable:$communityProbeStable,communityProbeTotal:$communityProbeTotal,communityScore:$communityScore,communityResults:$communityResults,universalEligible:$universalEligible,reliable:$reliable,score:$score,error:(if $error == "" then null else $error end)}'
    rm -f "$probes_file" "$selected_file" "$successful_file" "$community_results_file"
}

run_benchmark() {
    local protocol="$1"
    local main_file bootstrap_file bootstrap_jsonl bootstrap_json main_jsonl final_file
    local total completed line id provider value profile result recommendation ranking confidence recommendation_reason current_candidate state message current_dns current_bootstrap

    case "$protocol" in
        udp|doh|dot) ;;
        *)
            write_status "error" "benchmark" "invalid_protocol" 0 0 0 "$$"
            return 1
            ;;
    esac

    main_file="$(mktemp)"
    bootstrap_file="$(mktemp)"
    bootstrap_jsonl="$(mktemp)"
    bootstrap_json="$(mktemp)"
    main_jsonl="$(mktemp)"
    final_file="$(mktemp)"
    trap "rm -f '$main_file' '$bootstrap_file' '$bootstrap_jsonl' '$bootstrap_json' '$main_jsonl' '$final_file'; rm -rf '$LOCK_DIR'" EXIT INT TERM

    write_main_candidates "$protocol" "$main_file" || return 1
    write_bootstrap_candidates "$bootstrap_file"
    total=$(( $(wc -l < "$main_file") + $(wc -l < "$bootstrap_file") ))
    completed=0
    write_status "running" "benchmark" "benchmarking_bootstrap" 0 0 "$total" "$$"

    while IFS='|' read -r id provider value profile; do
        [ -n "$id" ] || continue
        benchmark_bootstrap_candidate "$id" "$provider" "$value" "$profile" >> "$bootstrap_jsonl"
        completed=$((completed + 1))
        write_status "running" "benchmark" "benchmarking_bootstrap" $((completed * 100 / total)) "$completed" "$total" "$$"
    done < "$bootstrap_file"
    jq -s 'sort_by(.score) | reverse' "$bootstrap_jsonl" > "$bootstrap_json"

    while IFS='|' read -r id provider value profile; do
        [ -n "$id" ] || continue
        benchmark_main_candidate "$protocol" "$id" "$provider" "$value" "$profile" "$bootstrap_json" >> "$main_jsonl"
        completed=$((completed + 1))
        write_status "running" "benchmark" "benchmarking_main" $((completed * 100 / total)) "$completed" "$total" "$$"
    done < "$main_file"

    current_dns="$(uci -q get podkop.settings.dns_server 2> /dev/null || true)"
    current_bootstrap="$(uci -q get podkop.settings.bootstrap_dns_server 2> /dev/null || true)"
    ranking="$(jq -s '
        map(select(.reliable == true))
        | (map(select(.universalEligible == true))) as $universal
        | (if ($universal | length) > 0 then $universal else . end)
        | sort_by(.score)
        | reverse
    ' "$main_jsonl")"
    recommendation="$(printf '%s\n' "$ranking" | jq -c '.[0] // null')"
    confidence="$(printf '%s\n' "$ranking" | jq '
        if length < 2 then 100
        else
            (.[0].score - .[1].score) as $gap
            | ((.[0].jitterMs + .[1].jitterMs + 5) * 40) as $noise
            | (($gap * 100 / $noise) | floor)
            | if . < 0 then 0 elif . > 100 then 100 else . end
        end
    ')"
    recommendation_reason="clear_winner"
    if [ "$confidence" -lt 35 ] && [ "$recommendation" != "null" ]; then
        current_candidate="$(printf '%s\n' "$ranking" | jq -c --arg current "$current_dns" '
            .[0] as $best
            | (map(select(.dnsServer == $current))[0] // null) as $currentResult
            | if $currentResult != null
                and (($best.score - $currentResult.score) <= (($best.jitterMs + $currentResult.jitterMs + 5) * 40))
              then $currentResult else null end
        ')"
        if [ "$current_candidate" != "null" ]; then
            recommendation="$current_candidate"
            recommendation_reason="close_results_keep_current"
        else
            recommendation_reason="close_results"
        fi
    fi
    state="success"
    message="benchmark_complete"
    if [ "$recommendation" = "null" ]; then
        state="error"
        message="no_reliable_dns"
    fi
    jq -cn \
        --arg state "$state" --arg action "benchmark" --arg message "$message" --arg protocol "$protocol" \
        --arg updatedAt "$(updated_at)" --arg currentDnsServer "$current_dns" --arg currentBootstrapDnsServer "$current_bootstrap" \
        --arg recommendationReason "$recommendation_reason" --arg methodVersion "community-lists-v1" \
        --argjson pid "$$" --argjson recommendation "$recommendation" --argjson recommendationConfidence "$confidence" \
        --slurpfile results "$main_jsonl" --slurpfile bootstrapResults "$bootstrap_json" \
        '{state:$state,action:$action,message:$message,protocol:$protocol,progress:100,completed:($results | length),total:($results | length),pid:$pid,updatedAt:$updatedAt,methodVersion:$methodVersion,current:{dnsServer:$currentDnsServer,bootstrapDnsServer:$currentBootstrapDnsServer},recommendation:$recommendation,recommendationConfidence:$recommendationConfidence,recommendationReason:$recommendationReason,results:($results | sort_by(.score) | reverse),bootstrapResults:($bootstrapResults[0] // [])}' \
        > "$final_file"
    write_final_status "$final_file"
}

run_with_timeout() {
    local timeout_seconds="$1"
    shift
    local pid watchdog rc

    "$@" &
    pid="$!"
    (
        sleep "$timeout_seconds"
        kill "$pid" 2> /dev/null || true
        sleep 1
        kill -9 "$pid" 2> /dev/null || true
    ) > /dev/null 2>&1 &
    watchdog="$!"

    wait "$pid" 2> /dev/null
    rc="$?"
    kill -9 "$watchdog" 2> /dev/null || true
    [ "$rc" -eq 143 ] && return 124
    return "$rc"
}

save_previous_dns() {
    local tmp dns_type dns_server bootstrap_dns_server

    mkdir -p "$PERSIST_DIR"
    chmod 700 "$PERSIST_DIR" 2> /dev/null || true
    tmp="$PREVIOUS_FILE.tmp.$$"
    dns_type="$(uci -q get podkop.settings.dns_type 2> /dev/null || true)"
    dns_server="$(uci -q get podkop.settings.dns_server 2> /dev/null || true)"
    bootstrap_dns_server="$(uci -q get podkop.settings.bootstrap_dns_server 2> /dev/null || true)"
    jq -cn \
        --arg dnsType "$dns_type" --arg dnsServer "$dns_server" --arg bootstrapDnsServer "$bootstrap_dns_server" \
        --arg savedAt "$(updated_at)" \
        '{dnsType:$dnsType,dnsServer:$dnsServer,bootstrapDnsServer:$bootstrapDnsServer,savedAt:$savedAt}' \
        > "$tmp" && mv "$tmp" "$PREVIOUS_FILE"
    chmod 600 "$PREVIOUS_FILE"
}

restore_previous_dns() {
    local dns_type dns_server bootstrap_dns_server

    [ -s "$PREVIOUS_FILE" ] || return 1
    dns_type="$(jq -r '.dnsType // empty' "$PREVIOUS_FILE")"
    dns_server="$(jq -r '.dnsServer // empty' "$PREVIOUS_FILE")"
    bootstrap_dns_server="$(jq -r '.bootstrapDnsServer // empty' "$PREVIOUS_FILE")"
    [ -n "$dns_type" ] && [ -n "$dns_server" ] && [ -n "$bootstrap_dns_server" ] || return 1

    uci set "podkop.settings.dns_type=$dns_type"
    uci set "podkop.settings.dns_server=$dns_server"
    uci set "podkop.settings.bootstrap_dns_server=$bootstrap_dns_server"
    uci commit podkop
}

restart_podkop() {
    : > "$LOG_FILE"
    run_with_timeout 90 env PODKOP_SUBSCRIPTION_CACHE_ONLY=1 PODKOP_SKIP_LIST_UPDATE=1 \
        /usr/bin/podkop restart >> "$LOG_FILE" 2>&1
}

validate_service_compatibility() {
    local server="$1"
    local probes selected successful scope service domain round output total passed success_count

    probes="$(mktemp)"
    selected="$(mktemp)"
    successful="$(mktemp)"
    printf '__probe_sentinel__\n' > "$successful"
    write_compatibility_domains "$probes" "$selected"
    for round in 1 2; do
        while IFS='|' read -r scope service domain; do
            [ -n "$domain" ] || continue
            output="$(run_dns_query udp "$server" "" "" "$domain" NOERROR 2> /dev/null || true)"
            [ -n "$output" ] && printf '%s|%s|%s\n' "$scope" "$service" "$domain" >> "$successful"
        done < "$probes"
    done

    total="$(wc -l < "$probes" | tr -d ' ')"
    passed="$(awk -F '|' '
        NR == FNR { successes[$0]++; next }
        successes[$1 "|" $2 "|" $3] >= 1 { passed++ }
        END { print passed + 0 }
    ' "$successful" "$probes")"
    success_count="$(wc -l < "$successful" | tr -d ' ')"
    success_count=$((success_count - 1))
    rm -f "$probes" "$selected" "$successful"
    [ "$passed" -eq "$total" ] && [ "$success_count" -ge $((total * 2 - 1)) ]
}

validate_podkop_dns() {
    local config_path dont_touch server noresolv cachesize output

    [ "${PODKOP_DNS_OPTIMIZER_TEST_FAIL_VALIDATION:-0}" != "1" ] || return 1

    config_path="$(uci -q get podkop.settings.config_path 2> /dev/null || true)"
    [ -n "$config_path" ] || config_path="/etc/sing-box/config.json"
    [ -s "$config_path" ] || return 1
    sing-box check -c "$config_path" > /dev/null 2>&1 || return 1
    /etc/init.d/sing-box status > /dev/null 2>&1 || return 1

    output="$(dig @127.0.0.42 example.com A +timeout=3 +tries=1 +stats 2> /dev/null)"
    printf '%s\n' "$output" | grep -q 'status: NOERROR' || return 1
    output="$(dig @127.0.0.42 fakeip.podkop.fyi A +timeout=3 +tries=1 +short 2> /dev/null)"
    printf '%s\n' "$output" | grep -Eq '^198\.(18|19)\.' || return 1
    validate_service_compatibility 127.0.0.42 || return 1

    dont_touch="$(uci -q get podkop.settings.dont_touch_dhcp 2> /dev/null || echo 0)"
    if [ "$dont_touch" != "1" ]; then
        server="$(uci -q get dhcp.@dnsmasq[0].server 2> /dev/null || true)"
        noresolv="$(uci -q get dhcp.@dnsmasq[0].noresolv 2> /dev/null || true)"
        cachesize="$(uci -q get dhcp.@dnsmasq[0].cachesize 2> /dev/null || true)"
        printf ' %s ' "$server" | grep -q ' 127.0.0.42 ' || return 1
        [ "$noresolv" = "1" ] || return 1
        [ "$cachesize" = "0" ] || return 1
        dig @127.0.0.1 fakeip.podkop.fyi A +timeout=3 +tries=1 +short 2> /dev/null | grep -Eq '^198\.(18|19)\.' || return 1
        validate_service_compatibility 127.0.0.1 || return 1
    fi
}

lookup_main_candidate() {
    local protocol="$1"
    local wanted_id="$2"
    local file line

    file="$(mktemp)"
    write_main_candidates "$protocol" "$file" || {
        rm -f "$file"
        return 1
    }
    line="$(awk -F '|' -v id="$wanted_id" '$1 == id { print; exit }' "$file")"
    rm -f "$file"
    [ -n "$line" ] || return 1
    printf '%s\n' "$line"
}

bootstrap_is_allowed() {
    local wanted="$1"
    local file

    file="$(mktemp)"
    write_bootstrap_candidates "$file"
    if awk -F '|' -v server="$wanted" '$3 == server { found = 1 } END { exit !found }' "$file"; then
        rm -f "$file"
        return 0
    fi
    rm -f "$file"
    return 1
}

write_apply_final() {
    local state="$1"
    local message="$2"
    local protocol="$3"
    local provider="$4"
    local dns_server="$5"
    local bootstrap="$6"
    local rolled_back="$7"
    local operation="${8:-apply}"
    local final_file

    final_file="$(mktemp)"
    jq -cn \
        --arg state "$state" --arg operation "$operation" --arg message "$message" --arg protocol "$protocol" \
        --arg provider "$provider" --arg dnsServer "$dns_server" --arg bootstrapDnsServer "$bootstrap" \
        --arg updatedAt "$(updated_at)" --argjson pid "$$" --argjson rolledBack "$rolled_back" \
        --argjson backupAvailable "$( [ -s "$PREVIOUS_FILE" ] && echo true || echo false )" \
        '{state:$state,action:"completed",operation:$operation,message:$message,progress:100,completed:1,total:1,pid:$pid,updatedAt:$updatedAt,applied:{protocol:$protocol,provider:$provider,dnsServer:$dnsServer,bootstrapDnsServer:$bootstrapDnsServer},rolledBack:$rolledBack,backupAvailable:$backupAvailable}' \
        > "$final_file"
    write_final_status "$final_file"
    rm -f "$final_file"
}

run_apply() {
    local protocol="$1"
    local candidate_id="$2"
    local bootstrap="$3"
    local line provider dns_server host resolved

    trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM
    line="$(lookup_main_candidate "$protocol" "$candidate_id" || true)"
    if [ -z "$line" ] || ! bootstrap_is_allowed "$bootstrap"; then
        write_apply_final "error" "invalid_recommendation" "$protocol" "" "" "$bootstrap" false
        return 1
    fi
    provider="$(printf '%s\n' "$line" | cut -d '|' -f 2)"
    dns_server="$(printf '%s\n' "$line" | cut -d '|' -f 3)"
    host="$(candidate_host "$dns_server")"
    if ! is_ipv4 "$host"; then
        resolved="$(resolve_host "$bootstrap" "$host")"
        if [ -z "$resolved" ]; then
            write_apply_final "error" "bootstrap_incompatible" "$protocol" "$provider" "$dns_server" "$bootstrap" false
            return 1
        fi
    fi

    write_status "running" "apply" "saving_previous_dns" 10 0 1 "$$"
    save_previous_dns || {
        write_apply_final "error" "backup_failed" "$protocol" "$provider" "$dns_server" "$bootstrap" false
        return 1
    }

    uci set "podkop.settings.dns_type=$protocol"
    uci set "podkop.settings.dns_server=$dns_server"
    uci set "podkop.settings.bootstrap_dns_server=$bootstrap"
    uci commit podkop

    write_status "running" "apply" "restarting_podkop" 45 0 1 "$$"
    if restart_podkop; then
        write_status "running" "apply" "validating_dns" 80 0 1 "$$"
        if validate_podkop_dns; then
            write_apply_final "success" "apply_complete" "$protocol" "$provider" "$dns_server" "$bootstrap" false
            return 0
        fi
    fi

    write_status "running" "apply" "rolling_back" 90 0 1 "$$"
    if restore_previous_dns; then
        restart_podkop > /dev/null 2>&1 || true
        write_apply_final "error" "apply_failed_rolled_back" "$protocol" "$provider" "$dns_server" "$bootstrap" true
    else
        write_apply_final "error" "apply_failed_rollback_failed" "$protocol" "$provider" "$dns_server" "$bootstrap" false
    fi
    return 1
}

run_rollback() {
    local previous_protocol previous_provider previous_dns previous_bootstrap

    trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM
    [ -s "$PREVIOUS_FILE" ] || {
        write_apply_final "error" "no_previous_dns" "" "" "" "" false "rollback"
        return 1
    }
    previous_protocol="$(jq -r '.dnsType // empty' "$PREVIOUS_FILE")"
    previous_dns="$(jq -r '.dnsServer // empty' "$PREVIOUS_FILE")"
    previous_bootstrap="$(jq -r '.bootstrapDnsServer // empty' "$PREVIOUS_FILE")"
    previous_provider="Previous DNS"

    write_status "running" "rollback" "rolling_back" 25 0 1 "$$"
    if restore_previous_dns && restart_podkop; then
        write_status "running" "rollback" "validating_dns" 80 0 1 "$$"
        if validate_podkop_dns; then
            write_apply_final "success" "rollback_complete" "$previous_protocol" "$previous_provider" "$previous_dns" "$previous_bootstrap" false "rollback"
            return 0
        fi
    fi
    write_apply_final "error" "rollback_failed" "$previous_protocol" "$previous_provider" "$previous_dns" "$previous_bootstrap" false "rollback"
    return 1
}

pid_alive() {
    local pid="$1"
    case "$pid" in
        ''|*[!0-9]*|0) return 1 ;;
    esac
    kill -0 "$pid" 2> /dev/null
}

start_worker() {
    local action="$1"
    shift
    local state pid

    ensure_state_dir
    if ! mkdir "$LOCK_DIR" 2> /dev/null; then
        state="$(jq -r '.state // ""' "$STATUS_FILE" 2> /dev/null || true)"
        pid="$(jq -r '.pid // 0' "$STATUS_FILE" 2> /dev/null || echo 0)"
        if [ "$state" = "running" ] && { [ "$pid" = "0" ] || pid_alive "$pid"; }; then
            echo '{"success":false,"error":"busy"}'
            return 1
        fi
        rm -rf "$LOCK_DIR"
        mkdir "$LOCK_DIR" 2> /dev/null || {
            echo '{"success":false,"error":"busy"}'
            return 1
        }
    fi

    write_status "running" "$action" "starting" 0 0 1 0
    if command -v start-stop-daemon > /dev/null 2>&1; then
        if ! start-stop-daemon -S -b -x "$SELF" -- __worker "$action" "$@" < /dev/null > /dev/null 2>&1; then
            rm -rf "$LOCK_DIR"
            write_status "error" "$action" "worker_start_failed" 100 0 1 0
            echo '{"success":false,"error":"worker_start_failed"}'
            return 1
        fi
    elif command -v setsid > /dev/null 2>&1; then
        setsid "$SELF" __worker "$action" "$@" < /dev/null > "$LOG_FILE" 2>&1 &
    else
        "$SELF" __worker "$action" "$@" < /dev/null > "$LOG_FILE" 2>&1 &
    fi
    echo '{"success":true,"started":true}'
}

show_status() {
    local state pid tmp backup_available

    if [ ! -s "$STATUS_FILE" ]; then
        echo '{"state":"idle","action":"","message":"idle","progress":0,"completed":0,"total":0,"pid":0}'
        return 0
    fi
    state="$(jq -r '.state // ""' "$STATUS_FILE" 2> /dev/null || true)"
    pid="$(jq -r '.pid // 0' "$STATUS_FILE" 2> /dev/null || echo 0)"
    if [ "$state" = "running" ] && [ "$pid" != "0" ] && ! pid_alive "$pid"; then
        tmp="$STATUS_FILE.tmp.$$"
        jq '.state = "error" | .message = "worker_stopped" | .progress = 100' "$STATUS_FILE" > "$tmp" && mv "$tmp" "$STATUS_FILE"
        rm -rf "$LOCK_DIR"
    fi
    backup_available=false
    [ -s "$PREVIOUS_FILE" ] && backup_available=true
    jq --argjson backupAvailable "$backup_available" '.backupAvailable = $backupAvailable' "$STATUS_FILE"
}

show_help() {
    cat <<EOF
Usage: podkop-dns-optimizer <command>

Commands:
  benchmark_start [udp|doh|dot]
  apply_start <protocol> <candidate_id> <bootstrap_ipv4>
  rollback_start
  status
  version
EOF
}

case "${1:-}" in
    benchmark_start)
        start_worker "benchmark" "${2:-udp}"
        ;;
    apply_start)
        [ -n "${2:-}" ] && [ -n "${3:-}" ] && [ -n "${4:-}" ] || {
            echo '{"success":false,"error":"arguments_required"}'
            exit 1
        }
        start_worker "apply" "$2" "$3" "$4"
        ;;
    rollback_start)
        start_worker "rollback"
        ;;
    status)
        show_status
        ;;
    version)
        printf '%s\n' "$VERSION"
        ;;
    __worker)
        action="${2:-}"
        shift 2
        case "$action" in
            benchmark) run_benchmark "${1:-udp}" ;;
            apply) run_apply "${1:-}" "${2:-}" "${3:-}" ;;
            rollback) run_rollback ;;
            *) rm -rf "$LOCK_DIR"; exit 1 ;;
        esac
        ;;
    *)
        show_help
        exit 1
        ;;
esac
