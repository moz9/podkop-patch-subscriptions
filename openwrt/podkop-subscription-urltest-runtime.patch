+clash_api_get_proxy_now() {
+    local clash_url="$1"
+    local auth_header="$2"
+    local proxy_tag="$3"
+
+    curl -s --header "$auth_header" "$clash_url/proxies/$proxy_tag" | jq -r '.now // ""'
+}
+
+clash_api_wait_proxy_now() {
+    local clash_url="$1"
+    local auth_header="$2"
+    local proxy_tag="$3"
+    local attempts="${4:-15}"
+    local proxy_now attempt
+
+    for attempt in $(seq 1 "$attempts"); do
+        proxy_now="$(clash_api_get_proxy_now "$clash_url" "$auth_header" "$proxy_tag")"
+        if [ -n "$proxy_now" ]; then
+            echo "$proxy_now"
+            return 0
+        fi
+        sleep 1
+    done
+
+    return 1
+}
+
+clash_api_set_group_proxy_raw() {
+    local clash_url="$1"
+    local auth_header="$2"
+    local group_tag="$3"
+    local proxy_tag="$4"
+    local response http_code
+
+    response=$(
+        curl -X PUT -s -w "\n%{http_code}" "$clash_url/proxies/$group_tag" \
+            --header "$auth_header" \
+            --data-raw "{\"name\":\"$proxy_tag\"}"
+    )
+    http_code="$(echo "$response" | tail -n 1)"
+
+    [ "$http_code" = "204" ]
+}
