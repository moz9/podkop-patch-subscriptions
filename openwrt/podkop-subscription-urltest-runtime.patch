+apply_subscription_exclusions_to_cached_links() {
+    local section="$1"
+    local cache_path all_cache_path items_cache_path excluded_ids_file active_links_file tmp_cache tmp_items_cache \
+        excluded_ids_json link link_id items_json
+
+    SUBSCRIPTION_CACHE_CHANGED=0
+    cache_path="$(get_subscription_cache_path "$section")"
+    all_cache_path="$(get_subscription_all_cache_path "$section")"
+    items_cache_path="$(get_subscription_items_cache_path "$section")"
+    excluded_ids_file="$(mktemp)"
+    active_links_file="$(mktemp)"
+
+    if [ ! -s "$all_cache_path" ] && [ -s "$cache_path" ]; then
+        cp "$cache_path" "$all_cache_path"
+        chmod 600 "$all_cache_path" 2> /dev/null
+    fi
+
+    if [ ! -s "$all_cache_path" ]; then
+        rm -f "$excluded_ids_file" "$active_links_file"
+        return 1
+    fi
+
+    collect_subscription_excluded_ids "$section" "$excluded_ids_file"
+    : > "$active_links_file"
+
+    while IFS= read -r link || [ -n "$link" ]; do
+        [ -n "$link" ] || continue
+        link_id="$(get_subscription_link_id "$link")"
+        if ! is_subscription_link_id_excluded "$link_id" "$excluded_ids_file"; then
+            printf '%s\n' "$link" >> "$active_links_file"
+        fi
+    done < "$all_cache_path"
+
+    if [ ! -s "$active_links_file" ]; then
+        rm -f "$excluded_ids_file" "$active_links_file"
+        return 1
+    fi
+
+    if [ ! -f "$cache_path" ] || ! cmp -s "$active_links_file" "$cache_path"; then
+        tmp_cache="$cache_path.tmp.$$"
+        if cp "$active_links_file" "$tmp_cache" && mv "$tmp_cache" "$cache_path"; then
+            chmod 600 "$cache_path" 2> /dev/null
+            SUBSCRIPTION_CACHE_CHANGED=1
+        else
+            rm -f "$tmp_cache" "$excluded_ids_file" "$active_links_file"
+            return 1
+        fi
+    fi
+
+    if [ -s "$items_cache_path" ]; then
+        excluded_ids_json="$(jq -R -s -c 'split("\n") | map(select(length > 0))' "$excluded_ids_file")"
+        tmp_items_cache="$items_cache_path.tmp.$$"
+        items_json="$(jq -c --argjson excludedIds "$excluded_ids_json" '
+            map(
+                if .supported == true then
+                    . as $item
+                    | .enabled = (($excludedIds | index($item.id)) == null)
+                    | .reason = (if (($excludedIds | index($item.id)) == null) then "" else "user_excluded" end)
+                else
+                    .
+                end
+            )
+        ' "$items_cache_path")"
+        if printf '%s\n' "$items_json" > "$tmp_items_cache" && mv "$tmp_items_cache" "$items_cache_path"; then
+            chmod 600 "$items_cache_path" 2> /dev/null
+        else
+            rm -f "$tmp_items_cache"
+            log "Failed to update subscription items cache for section '$section'" "warn"
+        fi
+    fi
+
+    rm -f "$excluded_ids_file" "$active_links_file"
+    return 0
+}
+
+set_subscription_link_enabled() {
+    local section="$1"
+    local link_id="$2"
+    local enabled="$3"
+
+    set_subscription_links_enabled "$section" "$link_id" "$enabled"
+}
+
+set_subscription_links_enabled() {
+    local section="$1"
+    local items_cache_path excluded_ids_file tmp_excluded_file link_id enabled enabled_value \
+        excluded_ids_json remaining_enabled_count changed_count reload_required
+
+    if [ "$#" -lt 3 ] || [ $((($# - 1) % 2)) -ne 0 ]; then
+        echo '{"success":false,"error":"invalid_arguments"}'
+        return 1
+    fi
+
+    if ! validate_subscription_urltest_section "$section"; then
+        echo '{"success":false,"error":"section_is_not_subscription_urltest"}'
+        return 1
+    fi
+
+    shift
+
+    items_cache_path="$(get_subscription_items_cache_path "$section")"
+    if [ ! -s "$items_cache_path" ]; then
+        refresh_subscription_cache "$section" > /dev/null 2>&1 || true
+    fi
+
+    if [ ! -s "$items_cache_path" ]; then
+        echo '{"success":false,"error":"subscription_cache_missing"}'
+        return 1
+    fi
+
+    excluded_ids_file="$(mktemp)"
+    collect_subscription_excluded_ids "$section" "$excluded_ids_file"
+    changed_count=0
+
+    while [ "$#" -gt 0 ]; do
+        link_id="$1"
+        enabled="$2"
+        shift 2
+
+        if ! validate_subscription_link_id "$link_id"; then
+            rm -f "$excluded_ids_file"
+            echo '{"success":false,"error":"invalid_arguments"}'
+            return 1
+        fi
+
+        enabled_value="$(normalize_subscription_enabled_value "$enabled")"
+        if [ -z "$enabled_value" ]; then
+            rm -f "$excluded_ids_file"
+            echo '{"success":false,"error":"invalid_enabled_value"}'
+            return 1
+        fi
+
+        if ! jq -e --arg id "$link_id" 'any(.[]; .id == $id and .supported == true)' "$items_cache_path" > /dev/null 2>&1; then
+            rm -f "$excluded_ids_file"
+            echo '{"success":false,"error":"link_is_not_supported"}'
+            return 1
+        fi
+
+        tmp_excluded_file="$(mktemp)"
+        grep -Fxv "$link_id" "$excluded_ids_file" > "$tmp_excluded_file" 2> /dev/null || true
+        if [ "$enabled_value" -eq 0 ]; then
+            printf '%s\n' "$link_id" >> "$tmp_excluded_file"
+        fi
+        awk '!seen[$0]++' "$tmp_excluded_file" > "$excluded_ids_file"
+        rm -f "$tmp_excluded_file"
+        changed_count=$((changed_count + 1))
+    done
+
+    excluded_ids_json="$(jq -R -s -c 'split("\n") | map(select(length > 0))' "$excluded_ids_file")"
+    remaining_enabled_count="$(jq --argjson excludedIds "$excluded_ids_json" '
+        [
+            .[]
+            | select(
+                .supported == true
+                and (. as $item | ($excludedIds | index($item.id)) == null)
+            )
+        ] | length
+    ' "$items_cache_path" 2> /dev/null || echo 0)"
+
+    if [ "$remaining_enabled_count" -eq 0 ]; then
+        rm -f "$excluded_ids_file"
+        echo '{"success":false,"error":"cannot_disable_last_enabled_link"}'
+        return 1
+    fi
+
+    uci -q delete "podkop.$section.subscription_excluded_link_ids"
+    while IFS= read -r link_id || [ -n "$link_id" ]; do
+        [ -n "$link_id" ] || continue
+        uci -q add_list "podkop.$section.subscription_excluded_link_ids=$link_id"
+    done < "$excluded_ids_file"
+    rm -f "$excluded_ids_file"
+
+    if ! uci commit podkop; then
+        echo '{"success":false,"error":"uci_commit_failed"}'
+        return 1
+    fi
+
+    config_load "$PODKOP_CONFIG"
+    if ! apply_subscription_exclusions_to_cached_links "$section"; then
+        if ! refresh_subscription_cache "$section" > /dev/null 2>&1; then
+            echo '{"success":false,"error":"subscription_cache_update_failed"}'
+            return 1
+        fi
+    fi
+
+    reload_required="$SUBSCRIPTION_CACHE_CHANGED"
+    if [ "$reload_required" -eq 1 ]; then
+        if ! PODKOP_SUBSCRIPTION_CACHE_ONLY=1 PODKOP_SKIP_LIST_UPDATE=1 /usr/bin/podkop reload > /dev/null 2>&1; then
+            echo '{"success":false,"error":"reload_failed"}'
+            return 1
+        fi
+    fi
+
+    printf '{"success":true,"changed":%s,"reloaded":%s}\n' "$changed_count" "$reload_required"
+}
+
+subscription_update_section_handler() {
+    local section="$1"
+    local connection_type proxy_config_type
+
+    if [ -n "$SUBSCRIPTION_UPDATE_TARGET" ] && [ "$SUBSCRIPTION_UPDATE_TARGET" != "$section" ]; then
+        return 0
+    fi
+
+    config_get connection_type "$section" "connection_type"
+    config_get proxy_config_type "$section" "proxy_config_type"
+
+    if [ "$connection_type" != "proxy" ] || [ "$proxy_config_type" != "subscription_urltest" ] ||
+        ! section_has_subscription_urls "$section"; then
+        return 0
+    fi
+
+    SUBSCRIPTION_FOUND_SECTIONS=$((SUBSCRIPTION_FOUND_SECTIONS + 1))
+    if refresh_subscription_cache "$section"; then
+        if [ "$SUBSCRIPTION_CACHE_CHANGED" -eq 1 ]; then
+            SUBSCRIPTION_UPDATED_SECTIONS=$((SUBSCRIPTION_UPDATED_SECTIONS + 1))
+        fi
+    else
+        SUBSCRIPTION_FAILED_SECTIONS=$((SUBSCRIPTION_FAILED_SECTIONS + 1))
+    fi
+}
+
+subscription_update() {
+    SUBSCRIPTION_UPDATE_TARGET="$1"
+    SUBSCRIPTION_FOUND_SECTIONS=0
+    SUBSCRIPTION_UPDATED_SECTIONS=0
+    SUBSCRIPTION_FAILED_SECTIONS=0
+
+    if subscription_runtime_busy; then
+        echolog "Subscription runtime is busy, skipping subscription update"
+        return 0
+    fi
+
+    if ! subscription_action_lock_acquire "subscription_update"; then
+        echolog "Subscription runtime is busy, skipping subscription update"
+        return 0
+    fi
+    trap 'subscription_action_lock_release' EXIT INT TERM
+
+    echolog "Starting subscription update..."
+    config_foreach subscription_update_section_handler "section"
+
+    if [ "$SUBSCRIPTION_FOUND_SECTIONS" -eq 0 ]; then
+        echolog "No Subscription URLTest sections found"
+        return 0
+    fi
+
+    if [ "$SUBSCRIPTION_UPDATED_SECTIONS" -gt 0 ]; then
+        echolog "Subscription cache changed, reloading podkop..."
+        PODKOP_SUBSCRIPTION_CACHE_ONLY=1 PODKOP_SKIP_LIST_UPDATE=1 /usr/bin/podkop reload
+        return $?
+    fi
+
+    if [ "$SUBSCRIPTION_FAILED_SECTIONS" -gt 0 ]; then
+        echolog "Subscription update finished with failures; cached subscriptions were kept"
+        return 1
+    fi
+
+    echolog "Subscription update completed, no changes"
+}
+
+subscription_update_json() {
+    local section="$1"
+    local output status success
+
+    output="$(subscription_update "$section" 2>&1)"
+    status=$?
+    if [ "$status" -eq 0 ]; then
+        success=true
+    else
+        success=false
+    fi
+
+    jq -cn --argjson success "$success" --arg output "$output" --argjson status "$status" \
+        '{success:$success, status:$status, output:$output}'
+}
