+get_subscription_cron_schedule() {
+    local interval="$1"
+
+    case "$interval" in
+    "10m")
+        echo "*/10 * * * *"
+        ;;
+    "30m")
+        echo "17,47 * * * *"
+        ;;
+    "1h")
+        echo "17 * * * *"
+        ;;
+    "3h")
+        echo "17 */3 * * *"
+        ;;
+    "6h")
+        echo "17 */6 * * *"
+        ;;
+    "12h")
+        echo "17 */12 * * *"
+        ;;
+    "1d")
+        echo "17 9 * * *"
+        ;;
+    *)
+        return 1
+        ;;
+    esac
+}
