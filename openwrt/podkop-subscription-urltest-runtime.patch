+add_subscription_cron_job() {
+    local section="$1"
+    local connection_type proxy_config_type subscription_update_interval cron_schedule cron_job
+
+    config_get connection_type "$section" "connection_type"
+    config_get proxy_config_type "$section" "proxy_config_type"
+
+    if [ "$connection_type" != "proxy" ] || [ "$proxy_config_type" != "subscription_urltest" ] ||
+        ! section_has_subscription_urls "$section"; then
+        return 0
+    fi
+
+    config_get subscription_update_interval "$section" "subscription_update_interval" "1h"
+    cron_schedule="$(get_subscription_cron_schedule "$subscription_update_interval")"
+    if [ -z "$cron_schedule" ]; then
+        log "Invalid subscription_update_interval value for section '$section': $subscription_update_interval" "warn"
+        cron_schedule="$(get_subscription_cron_schedule "1h")"
+    fi
+
+    case "$section" in
+    "" | *[!A-Za-z0-9_]*)
+        log "Skipping subscription cron job for section with unsupported name '$section'" "warn"
+        return 1
+        ;;
+    esac
+
+    cron_job="$cron_schedule /usr/bin/podkop subscription_update $section"
+    crontab -l 2> /dev/null | {
+        cat
+        echo "$cron_job"
+    } | crontab -
+    log "The subscription cron job has been created for section '$section'"
+}
