+normalize_subscription_enabled_value() {
+    local enabled="$1"
+
+    case "$enabled" in
+    1 | true | on | enabled)
+        echo "1"
+        return 0
+        ;;
+    0 | false | off | disabled)
+        echo "0"
+        return 0
+        ;;
+    esac
+
+    return 1
+}
