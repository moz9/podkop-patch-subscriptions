+validate_subscription_link_id() {
+    local link_id="$1"
+
+    if [ "${#link_id}" -ne 32 ]; then
+        return 1
+    fi
+
+    case "$link_id" in
+    *[!A-Fa-f0-9]*) return 1 ;;
+    esac
+
+    return 0
+}
