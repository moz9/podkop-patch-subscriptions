+validate_subscription_urltest_section() {
+    local section="$1"
+    local connection_type proxy_config_type
+
+    if ! validate_subscription_section_name "$section"; then
+        return 1
+    fi
+
+    config_get connection_type "$section" "connection_type"
+    config_get proxy_config_type "$section" "proxy_config_type"
+    [ "$connection_type" = "proxy" ] && [ "$proxy_config_type" = "subscription_urltest" ]
+}
